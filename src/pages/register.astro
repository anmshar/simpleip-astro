---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---
<Base title="SimpleIP — Create your free account">
  <Nav />

  <!-- Blurred dashboard background -->
  <div class="reg-bg">
    <div class="reg-bg-frame">
      <div class="reg-bg-sidebar">
        <div class="reg-bg-logo">SimpleIP</div>
        <div class="reg-sidebar-items">
          <div class="reg-sb-item">
            <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 3v5H3"/><circle cx="7" cy="8" r="5"/><path d="M15 15l-3-3"/></svg>
            My patents
          </div>
          <div class="reg-sb-item active">
            <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 6A4 4 0 005 6c0 4.5-2 6-2 6h12S13 10.5 13 6z"/><path d="M10 15a1.5 1.5 0 01-3 0"/></svg>
            Monitoring
          </div>
          <div class="reg-sb-item">
            <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 15V6l3.5-3 3.5 4 5-4v12H3z"/></svg>
            Landscape
          </div>
          <div class="reg-sb-item">
            <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="12" height="12" rx="2"/><path d="M3 8h12"/><path d="M8 3v12"/></svg>
            Smart file upload
          </div>
        </div>
      </div>
      <div class="reg-bg-main">
        <img src={`${import.meta.env.BASE_URL}screenshot-monitoring.png`} alt="" class="reg-bg-screenshot" />
      </div>
    </div>
  </div>

  <!-- Step 1: Loading state modal -->
  <div class="reg-overlay" id="step-loading">
    <div class="reg-modal" id="loadingModal">
      <div class="loading-spinner">
        <svg viewBox="0 0 40 40" fill="none">
          <circle cx="20" cy="20" r="16" stroke="#E5E3DF" stroke-width="3"/>
          <path d="M20 4a16 16 0 0112.65 6.2" stroke="var(--primary)" stroke-width="3" stroke-linecap="round">
            <animateTransform attributeName="transform" type="rotate" from="0 20 20" to="360 20 20" dur="1s" repeatCount="indefinite"/>
          </path>
        </svg>
      </div>
      <p class="loading-text">Creating your report...</p>
      <h2>Did you know SimpleIP is free and always will be?</h2>
      <ul class="loading-features">
        <li>
          <span class="lf-check">
            <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#2D8A6E"/><path d="M5 8.2l2 2 4-4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <div>
            <strong>Oversee your portfolio</strong>
            <span>Find and manage your patent families in seconds.</span>
          </div>
        </li>
        <li>
          <span class="lf-check">
            <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#2D8A6E"/><path d="M5 8.2l2 2 4-4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <div>
            <strong>Track competition</strong>
            <span>Get a monthly radar of competitor updates.</span>
          </div>
        </li>
        <li>
          <span class="lf-check">
            <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#2D8A6E"/><path d="M5 8.2l2 2 4-4" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <div>
            <strong>Assess new ideas</strong>
            <span>Generate AI novelty reports to vet your next invention.</span>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <!-- Step 2: Register CTA overlay -->
  <div class="reg-overlay hidden" id="step-signup">
    <div class="reg-signup-bar">
      <div class="signup-lock">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="4" y="9" width="12" height="9" rx="2"/><path d="M7 9V6a3 3 0 016 0v3"/></svg>
      </div>
      <span class="signup-label">REGISTER TO MONITOR YOUR COMPETITORS FOR FREE</span>
      <form class="signup-form" id="signupForm">
        <input type="email" name="email" placeholder="Enter your work email" required />
        <button type="submit">Sign up →</button>
      </form>
      <p class="signup-note">100% free · No credit card required</p>
    </div>
  </div>
</Base>

<script>
  // Preserve search param
  const params = new URLSearchParams(window.location.search);
  const company = params.get('company') || '';

  // After 3s loading, transition to signup state
  setTimeout(() => {
    document.getElementById('step-loading')?.classList.add('hidden');
    document.getElementById('step-signup')?.classList.remove('hidden');
  }, 3000);

  // Signup form
  document.getElementById('signupForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input[name="email"]') as HTMLInputElement;
    const email = input?.value.trim();
    if (!email) return;
    // In production: redirect to Keycloak with company param preserved
    const base = import.meta.env.BASE_URL;
    window.location.href = `${base}verify?email=${encodeURIComponent(email)}&company=${encodeURIComponent(company)}`;
  });
</script>

<style>
  .hidden { display: none !important; }

  /* ============================
     BLURRED DASHBOARD BACKGROUND
     ============================ */
  .reg-bg {
    position: fixed; inset: 0; z-index: 0;
    background: var(--bg-light);
    padding-top: 104px;
    filter: blur(3px) brightness(0.97);
    overflow: hidden;
  }
  .reg-bg-frame {
    display: flex; height: 100%;
    max-width: 1400px; margin: 0 auto;
    border-radius: 12px 12px 0 0; overflow: hidden;
    background: white;
    box-shadow: 0 -4px 40px rgba(0,0,0,0.06);
  }

  /* Fake sidebar */
  .reg-bg-sidebar {
    width: 180px; border-right: 1px solid var(--border);
    padding: 24px 16px; flex-shrink: 0;
    background: white;
  }
  .reg-bg-logo {
    font-size: 16px; font-weight: 800; color: var(--headline);
    margin-bottom: 32px; padding: 0 8px;
  }
  .reg-sidebar-items { display: flex; flex-direction: column; gap: 4px; }
  .reg-sb-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 8px;
    font-size: 12px; font-weight: 500; color: var(--body);
  }
  .reg-sb-item svg { width: 16px; height: 16px; flex-shrink: 0; }
  .reg-sb-item.active {
    background: rgba(26, 77, 92, 0.06); color: var(--primary); font-weight: 700;
  }

  /* Main screenshot area */
  .reg-bg-main { flex: 1; overflow: hidden; }
  .reg-bg-screenshot {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top left;
    display: block;
  }

  /* ============================
     OVERLAY — shared base
     ============================ */
  .reg-overlay {
    position: fixed; inset: 0; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(2px);
    padding: 24px;
    animation: fadeIn 0.4s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ============================
     STEP 1: LOADING MODAL
     ============================ */
  .reg-modal {
    background: white;
    border-radius: 20px;
    padding: 48px 44px;
    max-width: 520px; width: 100%;
    box-shadow: 0 24px 80px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04);
    text-align: center;
    animation: modalUp 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes modalUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .loading-spinner { margin-bottom: 20px; }
  .loading-spinner svg { width: 40px; height: 40px; }
  .loading-text {
    font-size: 13px; color: var(--body); margin-bottom: 24px;
    font-weight: 500;
  }
  .reg-modal h2 {
    font-size: 22px; font-weight: 800; color: var(--headline);
    letter-spacing: -0.5px; margin-bottom: 28px; line-height: 1.3;
  }

  .loading-features { list-style: none; text-align: left; }
  .loading-features li {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--border);
  }
  .loading-features li:last-child { padding-bottom: 0; }
  .lf-check { flex-shrink: 0; width: 24px; height: 24px; margin-top: 2px; }
  .lf-check svg { width: 24px; height: 24px; }
  .loading-features strong {
    display: block; font-size: 15px; font-weight: 700;
    color: var(--headline); margin-bottom: 3px;
  }
  .loading-features span {
    font-size: 13.5px; color: var(--body); line-height: 1.5;
  }

  /* ============================
     STEP 2: SIGNUP BAR
     ============================ */
  .reg-signup-bar {
    background: white;
    border-radius: 20px;
    padding: 36px 44px;
    max-width: 600px; width: 100%;
    box-shadow: 0 24px 80px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.04);
    text-align: center;
    animation: modalUp 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .signup-lock {
    width: 40px; height: 40px; margin: 0 auto 16px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(26, 77, 92, 0.06); border-radius: 12px;
    color: var(--primary);
  }
  .signup-lock svg { width: 20px; height: 20px; }
  .signup-label {
    display: block;
    font-size: 12px; font-weight: 700; letter-spacing: 1.5px;
    color: var(--headline); margin-bottom: 24px;
    text-transform: uppercase;
  }
  .signup-form {
    display: flex; gap: 8px; max-width: 460px; margin: 0 auto 16px;
  }
  .signup-form input {
    flex: 1; padding: 14px 18px; border: 1px solid var(--border);
    border-radius: 12px; font-size: 15px; color: var(--headline);
    outline: none; background: white;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .signup-form input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(26, 77, 92, 0.1);
  }
  .signup-form input::placeholder { color: #94A3B8; }
  .signup-form button {
    padding: 14px 28px; border: none; border-radius: 12px;
    background: var(--primary-dark); color: white;
    font-size: 15px; font-weight: 700; cursor: pointer;
    white-space: nowrap;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
  }
  .signup-form button:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(15, 44, 53, 0.25);
  }
  .signup-note {
    font-size: 12px; color: var(--body); font-weight: 500;
  }

  /* ============================
     RESPONSIVE
     ============================ */
  @media (max-width: 768px) {
    .reg-bg-sidebar { display: none; }
    .reg-modal { padding: 36px 28px; }
    .reg-signup-bar { padding: 28px 24px; }
    .signup-form { flex-direction: column; }
    .signup-form button { width: 100%; justify-content: center; }
    .reg-modal h2 { font-size: 20px; }
  }
</style>
