---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const mockResults = [
  { name: 'Siemens AG', country: 'DE', patents: 48231 },
  { name: 'Siemens Energy AG', country: 'DE', patents: 5102 },
  { name: 'Siemens Healthineers AG', country: 'DE', patents: 12840 },
  { name: 'Siemens Gamesa Renewable Energy', country: 'ES', patents: 3201 },
];
---
<Base title="SimpleIP — Create your free account">
  <Nav />

  <!-- Step 1: Select Organisation -->
  <section class="register-page" id="step-org">
    <div class="org-card">
      <div class="org-header">
        <a href="/" class="reg-logo"><img src="/logo.svg" alt="SimpleIP" class="reg-logo-img" /></a>
        <h1>Select your organisation</h1>
        <p>We found multiple matches for <strong id="orgQuery">your search</strong>. Choose the correct entity below.</p>
      </div>
      <!-- Search within step 1 -->
      <form class="org-search" id="orgSearchForm">
        <div class="org-search-icon">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="9" r="6"/><path d="M18 18l-4-4"/></svg>
        </div>
        <input type="text" id="orgSearchInput" name="query" placeholder="Search by company name..." />
        <button type="submit">Search</button>
      </form>
      <div class="results-list" id="resultsList">
        {mockResults.map(r => (
          <button type="button" class="result-row" data-company={r.name}>
            <div>
              <div class="result-name">{r.name}</div>
              <div class="result-meta">{r.country} · {r.patents.toLocaleString()} patents</div>
            </div>
            <span class="result-arrow">→</span>
          </button>
        ))}
      </div>
      <p class="org-note">Can't find your organisation? <button type="button" class="org-manual-link" id="skipToRegister">Register manually →</button></p>
    </div>
    <div class="register-side">
      <div class="side-content">
        <h2>What you get — free, forever.</h2>
        <ul class="side-list">
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Full patent portfolio overview</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Competitor monitoring alerts</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Professional IP reports</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> 100M+ patents from 80+ offices</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> No credit card required</li>
        </ul>
        <div class="side-trust">
          <p>Backed by <strong>Dennemeyer Group</strong></p>
          <p>Trusted since 1962 · 100+ countries</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2: Account creation -->
  <section class="register-page hidden" id="step-account">
    <div class="register-card">
      <div class="register-header">
        <a href="/" class="reg-logo"><img src="/logo.svg" alt="SimpleIP" class="reg-logo-img" /></a>
        <button type="button" class="back-btn" id="backToOrg">← Back to organisation</button>
        <h1>Create your free account</h1>
        <p>Start managing your patent portfolio in under 2 minutes.</p>
        <div class="selected-org" id="selectedOrgBadge" hidden>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M5 8h6M8 5v6"/></svg>
          <span id="selectedOrgName"></span>
        </div>
      </div>
      <form class="register-form" action="/verify" method="post">
        <input type="hidden" id="selectedCompany" name="company" />
        <div class="form-group">
          <label for="name">Full name</label>
          <input type="text" id="name" name="name" placeholder="Jane Müller" required />
        </div>
        <div class="form-group">
          <label for="email">Business email</label>
          <input type="email" id="email" name="email" placeholder="jane@company.com" required />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="At least 8 characters" required />
        </div>
        <button type="submit" class="register-btn">Create account →</button>
        <p class="register-terms">By creating an account you agree to our <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a>.</p>
      </form>
      <p class="register-signin">Already have an account? <a href="#">Sign in</a></p>
    </div>
    <div class="register-side">
      <div class="side-content">
        <h2>What you get — free, forever.</h2>
        <ul class="side-list">
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Full patent portfolio overview</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Competitor monitoring alerts</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> Professional IP reports</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> 100M+ patents from 80+ offices</li>
          <li><span class="check-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8l4 4 6-6"/></svg></span> No credit card required</li>
        </ul>
        <div class="side-trust">
          <p>Backed by <strong>Dennemeyer Group</strong></p>
          <p>Trusted since 1962 · 100+ countries</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const stepOrg = document.getElementById('step-org');
  const stepAccount = document.getElementById('step-account');
  const orgQuery = document.getElementById('orgQuery');
  const orgSearchInput = document.getElementById('orgSearchInput') as HTMLInputElement;
  const selectedOrgBadge = document.getElementById('selectedOrgBadge');
  const selectedOrgName = document.getElementById('selectedOrgName');
  const selectedCompany = document.getElementById('selectedCompany') as HTMLInputElement;

  // Pre-fill from URL params
  const params = new URLSearchParams(window.location.search);
  const company = params.get('company');
  if (company) {
    if (orgQuery) orgQuery.textContent = company;
    if (orgSearchInput) orgSearchInput.value = company;
  }

  // Select an organisation → go to step 2
  document.querySelectorAll('.result-row').forEach(row => {
    row.addEventListener('click', () => {
      const name = (row as HTMLElement).dataset.company || '';
      goToAccountStep(name);
    });
  });

  // Skip to register manually
  document.getElementById('skipToRegister')?.addEventListener('click', () => {
    goToAccountStep('');
  });

  // Back button
  document.getElementById('backToOrg')?.addEventListener('click', () => {
    stepAccount?.classList.add('hidden');
    stepOrg?.classList.remove('hidden');
    window.scrollTo(0, 0);
  });

  // Org search form
  document.getElementById('orgSearchForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In a real app this would search — for now just update the query text
    const query = orgSearchInput?.value.trim();
    if (orgQuery && query) orgQuery.textContent = query;
  });

  function goToAccountStep(companyName: string) {
    stepOrg?.classList.add('hidden');
    stepAccount?.classList.remove('hidden');
    if (selectedCompany) selectedCompany.value = companyName;
    if (companyName && selectedOrgBadge && selectedOrgName) {
      selectedOrgName.textContent = companyName;
      selectedOrgBadge.hidden = false;
    }
    window.scrollTo(0, 0);
  }
</script>

<style>
  .hidden { display: none !important; }

  .register-page {
    min-height: 100vh; display: flex; padding-top: 72px;
  }

  /* Shared side panel */
  .register-side {
    flex: 1;
    background: linear-gradient(165deg, #0D1531 0%, #1B2559 100%);
    display: flex; align-items: center; justify-content: center; padding: 60px;
    position: relative; overflow: hidden;
  }
  .register-side::before {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(59,91,219,0.2), transparent 70%);
    filter: blur(60px);
  }
  .side-content { max-width: 380px; position: relative; }
  .side-content h2 { font-size: 28px; font-weight: 900; color: white; letter-spacing: -0.5px; margin-bottom: 28px; }
  .side-list { list-style: none; }
  .side-list li {
    display: flex; align-items: center; gap: 14px;
    font-size: 15px; color: rgba(255,255,255,0.75); padding: 10px 0; font-weight: 500;
  }
  .check-icon {
    width: 24px; height: 24px; border-radius: 8px;
    background: rgba(34, 197, 94, 0.15); color: #22C55E;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .check-icon svg { width: 13px; height: 13px; }
  .side-trust { margin-top: 40px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); }
  .side-trust p { font-size: 13px; color: rgba(255,255,255,0.35); }
  .side-trust strong { color: rgba(255,255,255,0.6); }

  /* Logo */
  .reg-logo { display: inline-flex; margin-bottom: 24px; }
  .reg-logo-img { height: 22px; width: auto; }

  /* Step 1: Org selection */
  .org-card {
    flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding: 60px 48px; max-width: 580px; margin: 0 auto;
  }
  .org-header { margin-bottom: 28px; }
  .org-header h1 {
    font-size: clamp(24px, 3vw, 32px); font-weight: 900; color: var(--headline);
    letter-spacing: -0.5px; margin-bottom: 10px;
  }
  .org-header p { font-size: 15px; color: var(--body); line-height: 1.6; }
  .org-header strong { color: var(--headline); font-weight: 700; }

  .org-search {
    display: flex; align-items: center; margin-bottom: 24px;
    border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
    background: white; position: relative;
    transition: border-color 0.2s;
  }
  .org-search:focus-within { border-color: var(--primary); }
  .org-search-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    color: #94A3B8; width: 18px; height: 18px;
  }
  .org-search-icon svg { width: 18px; height: 18px; }
  .org-search input {
    flex: 1; padding: 14px 16px 14px 42px; border: none; outline: none;
    font-size: 14px; color: var(--headline); background: transparent;
  }
  .org-search input::placeholder { color: #94A3B8; }
  .org-search button {
    padding: 10px 20px; margin: 4px; border: none; cursor: pointer;
    background: var(--primary); color: white; border-radius: 8px;
    font-size: 13px; font-weight: 700; transition: background 0.2s;
  }
  .org-search button:hover { background: var(--primary-light); }

  .results-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
  .result-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 22px; border: 1px solid var(--border); border-radius: 14px;
    background: white; cursor: pointer; text-align: left;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    font: inherit;
  }
  .result-row:hover {
    border-color: var(--primary); background: rgba(59, 91, 219, 0.02);
    transform: translateX(4px);
  }
  .result-name { font-size: 16px; font-weight: 700; color: var(--headline); }
  .result-meta { font-size: 13px; color: var(--body); margin-top: 3px; }
  .result-arrow { font-size: 20px; color: var(--primary); font-weight: 600; }
  .org-note { font-size: 13px; color: var(--body); text-align: center; }
  .org-manual-link {
    color: var(--primary); font-weight: 700; background: none; border: none;
    cursor: pointer; font: inherit; font-size: 13px;
  }
  .org-manual-link:hover { text-decoration: underline; }

  /* Step 2: Account form */
  .register-card {
    flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding: 60px 48px; max-width: 540px; margin: 0 auto;
  }
  .register-header { margin-bottom: 28px; }
  .back-btn {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 13px; font-weight: 600; color: var(--primary);
    background: none; border: none; cursor: pointer; padding: 0;
    margin-bottom: 20px; font: inherit; font-size: 13px; font-weight: 600; color: var(--primary);
  }
  .back-btn:hover { text-decoration: underline; }
  .register-header h1 {
    font-size: 28px; font-weight: 900; color: var(--headline);
    letter-spacing: -0.5px; margin-bottom: 8px;
  }
  .register-header p { font-size: 15px; color: var(--body); }
  .selected-org {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px; border-radius: 10px; margin-top: 14px;
    background: rgba(59, 91, 219, 0.06); border: 1px solid rgba(59, 91, 219, 0.12);
    font-size: 13px; font-weight: 700; color: var(--primary);
  }
  .selected-org svg { width: 14px; height: 14px; }

  .form-group { margin-bottom: 18px; }
  .form-group label {
    display: block; font-size: 13px; font-weight: 600;
    color: var(--headline); margin-bottom: 6px;
  }
  .form-group input {
    width: 100%; padding: 12px 16px; border: 1px solid var(--border);
    border-radius: 10px; font-size: 15px; color: var(--headline);
    outline: none; transition: border-color 0.2s;
  }
  .form-group input:focus { border-color: var(--primary); }
  .form-group input::placeholder { color: #94A3B8; }
  .register-btn {
    width: 100%; padding: 14px; border: none; border-radius: 12px;
    background: var(--primary); color: white;
    font-size: 16px; font-weight: 700;
    cursor: pointer; transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    margin-top: 8px;
  }
  .register-btn:hover {
    background: var(--primary-light); transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(59, 91, 219, 0.3);
  }
  .register-terms { font-size: 12px; color: var(--body); margin-top: 14px; text-align: center; }
  .register-terms a { color: var(--primary); }
  .register-signin { font-size: 14px; color: var(--body); margin-top: 24px; text-align: center; }
  .register-signin a { color: var(--primary); font-weight: 700; }

  @media (max-width: 900px) {
    .register-page { flex-direction: column; }
    .org-card, .register-card { max-width: 100%; padding: 40px 24px; }
    .register-side { padding: 40px 24px; }
  }
</style>
