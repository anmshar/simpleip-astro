---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="The free, professional platform to find, track and monitor your IP — built on 60+ years of Dennemeyer expertise." />
  <meta name="theme-color" content="#264d5a" />
  <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/global.css`} />
  <title>{title}</title>
</head>
<body>
  <a class="skip-link" href="#content-start">Skip to content</a>
  <slot />
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
