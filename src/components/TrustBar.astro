---
---
<section class="trust-bar">
  <div class="trust-bar-inner">
    <p class="trust-stripe">Backed by <strong>Dennemeyer</strong>, one of the world's leading IP groups, operating across 180+ jurisdictions since 1962.</p>
  </div>
</section>

<style>
  .trust-bar {
    background: #f7f9fa;
    padding: 48px 24px 60px; text-align: center;
    border-top: 1px solid #e2eaee;
    border-bottom: 1px solid #e2eaee;
    position: relative;
  }
  .trust-wave {
    position: absolute; top: -30px; left: 0; right: 0;
    height: 30px; pointer-events: none;
  }
  .trust-wave svg { width: 100%; height: 100%; display: block; }
  .trust-bar-inner { max-width: 900px; margin: 0 auto; }
  .trust-bar-label {
    font-size: 12px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 2.5px; color: var(--body); margin-bottom: 32px; opacity: 0.6;
  }
  .logo-row {
    display: flex; justify-content: center; align-items: center; gap: 56px;
    flex-wrap: wrap; max-width: 800px; margin: 0 auto 36px;
  }
  .logo-item {
    opacity: 0.4; filter: grayscale(100%);
    transition: opacity 0.4s, filter 0.4s, color 0.4s;
    cursor: default;
  }
  .logo-item img { height: 32px; max-width: 120px; width: auto; display: block; object-fit: contain; }
  .logo-item:hover { opacity: 1; filter: grayscale(0%); }
  .trust-badges {
    display: inline-flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap;
    padding: 12px 28px; border-radius: 100px;
    background: var(--white); border: 1px solid #e2eaee;
    box-shadow: 0 2px 12px rgba(27,37,89,0.04);
  }
  .trust-badge { display: flex; align-items: center; gap: 8px; }
  .trust-badge-stars { display: flex; gap: 2px; color: #ff6c2d; }
  .trust-badge-stars svg { width: 14px; height: 14px; }
  .trust-badge-text { font-size: 13px; color: var(--body); font-weight: 500; }
  .trust-badge-text strong { color: var(--headline); font-weight: 700; }
  .trust-badge-divider { width: 1px; height: 20px; background: #e2eaee; }

  @media (max-width: 768px) {
    .trust-bar { padding: 40px 20px 48px; }
    .trust-bar-label { font-size: 11px; letter-spacing: 2px; margin-bottom: 24px; }
    .logo-row { gap: 24px; margin-bottom: 28px; }
    .logo-item img { height: 24px; max-width: 100px; }
    .trust-badge-divider { display: none; }
    .trust-badges { flex-direction: column; gap: 12px; border-radius: 16px; padding: 16px 24px; }
  }

  @media (max-width: 480px) {
    .trust-bar { padding: 32px 16px 40px; }
    .trust-bar-label { font-size: 10px; letter-spacing: 1.5px; margin-bottom: 20px; padding: 0 8px; }
    .logo-row { gap: 20px; margin-bottom: 24px; }
    .logo-item img { height: 20px; max-width: 80px; }
    .trust-badges { padding: 14px 20px; gap: 10px; }
    .trust-badge-text { font-size: 12px; }
    .trust-badge-stars svg { width: 12px; height: 12px; }
  }

  @media (max-width: 320px) {
    .trust-bar { padding: 28px 12px 36px; }
    .trust-bar-label { font-size: 9px; letter-spacing: 1px; }
    .logo-row { gap: 16px; }
    .logo-item img { height: 18px; max-width: 70px; }
    .trust-badges { padding: 12px 16px; }
    .trust-badge-text { font-size: 11px; }
  }
</style>
