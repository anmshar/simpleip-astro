---
const cards = [
  {
    title: "Single point of contact",
    desc: "A friendly interface to one dedicated contact in case you need help or someone there to support."
  },
  {
    title: "Scalable IP solutions",
    desc: "Intellectual Property solutions respond to the size of your business and how this can change over time. Strategically expand and rethink the IP services you require from us."
  },
  {
    title: "Advanced IP technology",
    desc: "Software, applications, and platforms make the latest methods available. We simplify your workflow with digital IP services that are intelligent and intuitive."
  },
  {
    title: "Full service for IP portfolios",
    desc: "In addition to the full spectrum of IP-related legal services, Dennemeyer offers IP strategy consulting, IP management software, IP payment services and cutting-edge patent search and analysis tools."
  },
  {
    title: "Truly worldwide coverage",
    desc: "With 20+ offices across the globe, Dennemeyer manages over three million IP rights for around 8,000 customers. We are committed to securing IP rights everywhere our clients operate."
  },
  {
    title: "Regional expertise",
    desc: "Managing IP portfolios across jurisdictions requires deep local knowledge. Our regional experts ensure compliance with local IP regulations and procedures."
  }
];
---
<section class="ip-mgmt">
  <div class="ip-mgmt-inner">
    <div class="ip-mgmt-left">
      <p class="ip-label">The IP Group</p>
      <h2 class="ip-heading">Global Intellectual Property<br/>management</h2>
      <p class="ip-desc">
        Combining expertise in local IP procedures with the scope of a worldwide full-service provider, the Dennemeyer Group is your <strong>Intellectual Property management</strong> partner wherever you do business.
      </p>
      <div class="ip-help">
        <p><strong>Help?</strong> Talk to our experts.</p>
        <a href="mailto:info@simpleip.com" class="ip-contact-btn">Contact sales</a>
      </div>
    </div>
    <div class="ip-mgmt-right">
      <div class="ip-cards-track" id="ipCardsTrack">
        {cards.map((card, i) => (
          <div class="ip-card">
            <div class={`ip-card-illustration scene-${i}`}>
              <!-- Scene rendered via CSS -->
            </div>
            <div class="ip-card-body">
              <h3>{card.title}</h3>
              <p>{card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .ip-mgmt {
    padding: 100px 0;
    background: var(--bg-light);
    overflow: hidden;
  }
  .ip-mgmt-inner {
    display: flex; gap: 60px; align-items: flex-start;
    max-width: 1300px; margin: 0 auto; padding: 0 32px;
  }

  /* Left column — sticky text */
  .ip-mgmt-left {
    flex: 0 0 380px;
    position: sticky; top: 140px;
  }
  .ip-label {
    font-size: 13px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 2px; color: var(--primary); margin-bottom: 14px;
  }
  .ip-heading {
    font-size: clamp(28px, 3vw, 38px); font-weight: 800;
    color: var(--headline); line-height: 1.2;
    letter-spacing: -1px; margin-bottom: 20px;
  }
  .ip-desc {
    font-size: 15px; color: var(--body); line-height: 1.75;
    margin-bottom: 40px;
  }
  .ip-desc strong { color: var(--headline); font-weight: 700; }

  .ip-help p {
    font-size: 22px; color: var(--headline); margin-bottom: 20px;
    line-height: 1.3;
  }
  .ip-help strong { font-weight: 800; }
  .ip-contact-btn {
    display: inline-flex; align-items: center;
    padding: 12px 28px; border-radius: 8px;
    background: var(--orange); color: white;
    font-size: 14px; font-weight: 700;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(249,115,22,0.25);
  }
  .ip-contact-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(249,115,22,0.35);
  }

  /* Right column — horizontal scrolling cards */
  .ip-mgmt-right {
    flex: 1; min-width: 0;
    overflow-x: auto; overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
  }
  .ip-mgmt-right::-webkit-scrollbar { display: none; }

  .ip-cards-track {
    display: flex; gap: 20px;
    padding: 8px 60px 8px 0;
  }

  .ip-card {
    flex: 0 0 280px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .ip-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(27,37,89,0.08);
  }

  .ip-card-illustration {
    width: 100%; height: 210px;
    background: #FAFBFD;
    position: relative; overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  /* === Scene 0: Single point of contact — person with headset at desk === */
  .scene-0::before {
    content: ''; position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 120px; height: 8px; border-radius: 50%;
    background: rgba(27,37,89,0.06);
  }
  .scene-0::after {
    content: ''; position: absolute;
    bottom: 8px; left: 50%; transform: translateX(-50%);
    width: 80px; height: 100px;
    background:
      /* Head */
      radial-gradient(circle 18px at 50% 15px, #2D3047 18px, transparent 18px),
      /* Body */
      radial-gradient(ellipse 28px 35px at 50% 60px, #F97316 100%, transparent 0),
      /* Desk */
      linear-gradient(#1B2559, #1B2559) no-repeat center 88px / 100px 6px,
      /* Laptop */
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 22px 72px / 36px 20px,
      linear-gradient(#3B5BDB, #3B5BDB) no-repeat 26px 76px / 28px 12px,
      /* Headset */
      radial-gradient(circle 3px at 28px 12px, #F97316 3px, transparent 3px),
      linear-gradient(#F97316, #F97316) no-repeat 22px 8px / 2px 12px;
  }

  /* === Scene 1: Scalable IP — rising bar chart with arrow === */
  .scene-1::before {
    content: ''; position: absolute;
    bottom: 30px; left: 50%; transform: translateX(-50%);
    width: 160px; height: 130px;
    background:
      /* Chart bg */
      linear-gradient(white, white) no-repeat 0 0 / 160px 130px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 0 129px / 160px 1px;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }
  .scene-1::after {
    content: ''; position: absolute;
    bottom: 32px; left: 50%; transform: translateX(-50%);
    width: 140px; height: 110px;
    background:
      /* Bars */
      linear-gradient(#FFE0C2, #FFE0C2) no-repeat 8px 80px / 18px 28px,
      linear-gradient(#FBBF7A, #FBBF7A) no-repeat 32px 60px / 18px 48px,
      linear-gradient(#F97316, #F97316) no-repeat 56px 40px / 18px 68px,
      linear-gradient(#F97316, #F97316) no-repeat 80px 20px / 18px 88px,
      linear-gradient(#E8590C, #E8590C) no-repeat 104px 5px / 18px 103px,
      /* Arrow line */
      linear-gradient(135deg, transparent 48%, #1B2559 48%, #1B2559 52%, transparent 52%) no-repeat 10px 10px / 120px 80px;
  }

  /* === Scene 2: Advanced technology — screen with gears === */
  .scene-2::before {
    content: ''; position: absolute;
    bottom: 20px; left: 50%; transform: translateX(-50%);
    width: 140px; height: 110px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  .scene-2::after {
    content: ''; position: absolute;
    bottom: 30px; left: 50%; transform: translateX(-50%);
    width: 120px; height: 90px;
    background:
      /* Big gear */
      radial-gradient(circle 22px at 45px 45px, transparent 16px, #F97316 16px, #F97316 22px, transparent 22px),
      radial-gradient(circle 6px at 45px 45px, #F97316 6px, transparent 6px),
      /* Small gear */
      radial-gradient(circle 14px at 90px 30px, transparent 10px, #FBBF7A 10px, #FBBF7A 14px, transparent 14px),
      radial-gradient(circle 4px at 90px 30px, #FBBF7A 4px, transparent 4px),
      /* Circuit lines */
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 20px 75px / 80px 1.5px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 20px 82px / 60px 1.5px;
  }

  /* === Scene 3: Full service — dashboard with charts (from screenshot) === */
  .scene-3::before {
    content: ''; position: absolute;
    bottom: 15px; left: 15px; right: 15px; top: 15px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }
  .scene-3::after {
    content: ''; position: absolute;
    top: 25px; left: 25px; right: 25px; bottom: 25px;
    background:
      /* Whiteboard */
      linear-gradient(#F7F8FC, #F7F8FC) no-repeat 0 0 / 100% 55%,
      /* Pie chart */
      radial-gradient(circle 28px at 70% 25%, transparent 20px, #F97316 20px, #F97316 28px, transparent 28px),
      radial-gradient(circle 28px at 70% 25%, transparent 20px, #FFE0C2 20px, #FFE0C2 28px, transparent 28px),
      radial-gradient(circle 12px at 70% 25%, white 12px, transparent 12px),
      /* Bar chart left */
      linear-gradient(#FFE0C2, #FFE0C2) no-repeat 8% 30% / 8% 22%,
      linear-gradient(#FBBF7A, #FBBF7A) no-repeat 20% 20% / 8% 32%,
      linear-gradient(#F97316, #F97316) no-repeat 32% 12% / 8% 40%,
      /* Arrow */
      linear-gradient(#1B2559, #1B2559) no-repeat 10% 8% / 32% 2px,
      /* Text lines */
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 5% 65% / 90% 2px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 5% 73% / 70% 2px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 5% 81% / 80% 2px,
      /* Person silhouette left */
      radial-gradient(circle 10px at 20% 90%, #2D3047 10px, transparent 10px),
      radial-gradient(ellipse 14px 18px at 20% 110%, #E5E9F2 100%, transparent 0),
      /* Person silhouette right */
      radial-gradient(circle 10px at 80% 85%, #2D3047 10px, transparent 10px),
      radial-gradient(ellipse 14px 18px at 80% 106%, #F97316 100%, transparent 0);
  }

  /* === Scene 4: Worldwide — globe with pins === */
  .scene-4::before {
    content: ''; position: absolute;
    bottom: 25px; left: 50%; transform: translateX(-50%);
    width: 130px; height: 130px;
    border-radius: 50%;
    background: #FFF3E8;
    box-shadow: 0 4px 20px rgba(249,115,22,0.1);
  }
  .scene-4::after {
    content: ''; position: absolute;
    bottom: 25px; left: 50%; transform: translateX(-50%);
    width: 130px; height: 130px;
    border-radius: 50%;
    background:
      /* Meridians */
      radial-gradient(ellipse 25px 65px at 50% 50%, transparent 22px, #FFDCB8 22px, #FFDCB8 25px, transparent 25px),
      /* Equator */
      linear-gradient(transparent 48%, #FFDCB8 48%, #FFDCB8 52%, transparent 52%),
      /* Latitude lines */
      linear-gradient(transparent 28%, #FFDCB8 28%, #FFDCB8 30%, transparent 30%),
      linear-gradient(transparent 70%, #FFDCB8 70%, #FFDCB8 72%, transparent 72%),
      /* Pins */
      radial-gradient(circle 6px at 35% 35%, #F97316 6px, transparent 6px),
      radial-gradient(circle 5px at 60% 45%, #E8590C 5px, transparent 5px),
      radial-gradient(circle 4px at 75% 55%, #F97316 4px, transparent 4px),
      radial-gradient(circle 5px at 40% 65%, #FBBF7A 5px, transparent 5px),
      radial-gradient(circle 6px at 65% 30%, #F97316 6px, transparent 6px);
  }

  /* === Scene 5: Regional — building with flag === */
  .scene-5::before {
    content: ''; position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 160px; height: 8px; border-radius: 50%;
    background: rgba(27,37,89,0.06);
  }
  .scene-5::after {
    content: ''; position: absolute;
    bottom: 8px; left: 50%; transform: translateX(-50%);
    width: 140px; height: 160px;
    background:
      /* Building */
      linear-gradient(#F7F8FC, #F7F8FC) no-repeat 30px 50px / 80px 110px,
      /* Roof / triangle */
      linear-gradient(135deg, transparent 42%, #FFDCB8 42%, #FFDCB8 58%, transparent 58%) no-repeat 30px 20px / 80px 35px,
      /* Pillars */
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 40px 55px / 8px 100px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 56px 55px / 8px 100px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 72px 55px / 8px 100px,
      linear-gradient(#E5E9F2, #E5E9F2) no-repeat 88px 55px / 8px 100px,
      /* Door */
      linear-gradient(#1B2559, #1B2559) no-repeat 58px 115px / 24px 40px,
      /* Flag pole */
      linear-gradient(#1B2559, #1B2559) no-repeat 120px 15px / 2px 60px,
      /* Flag */
      linear-gradient(#F97316, #F97316) no-repeat 122px 15px / 18px 12px,
      /* Windows */
      radial-gradient(circle 4px at 48px 75px, #3B5BDB 4px, transparent 4px),
      radial-gradient(circle 4px at 70px 75px, #3B5BDB 4px, transparent 4px),
      radial-gradient(circle 4px at 92px 75px, #3B5BDB 4px, transparent 4px),
      radial-gradient(circle 4px at 48px 95px, #FBBF7A 4px, transparent 4px),
      radial-gradient(circle 4px at 70px 95px, #FBBF7A 4px, transparent 4px),
      radial-gradient(circle 4px at 92px 95px, #FBBF7A 4px, transparent 4px);
  }

  .ip-card-body {
    padding: 24px;
  }
  .ip-card-body h3 {
    font-size: 17px; font-weight: 800; color: var(--headline);
    margin-bottom: 10px; line-height: 1.3;
  }
  .ip-card-body p {
    font-size: 13.5px; color: var(--body); line-height: 1.7;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .ip-mgmt-inner {
      flex-direction: column; gap: 36px;
    }
    .ip-mgmt-left {
      flex: none; position: static;
      max-width: 100%;
    }
    .ip-mgmt-right {
      width: 100%;
      mask-image: linear-gradient(to right, black 90%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 90%, transparent 100%);
    }
    .ip-cards-track { padding-right: 40px; }
    .ip-card { flex: 0 0 240px; }
  }
  @media (max-width: 480px) {
    .ip-mgmt { padding: 64px 0; }
    .ip-card { flex: 0 0 220px; padding: 22px 18px; }
    .ip-heading { font-size: 26px; }
  }
</style>
