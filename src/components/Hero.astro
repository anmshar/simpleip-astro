---
---
<section class="hero">
  <div class="hero-content">
    <div class="hero-badge">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="8" fill="#2D8A6E" fill-opacity="0.12"/>
        <path d="M5 8.5L7 10.5L11 6" stroke="#2D8A6E" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      100% Free Forever
    </div>
    <h1>Take control of your IP<br/>from day one.</h1>
    <p class="hero-sub">The first AI-native patent workspace for growing companies, for free.</p>
    <form class="hero-search" id="heroSearchForm">
      <input type="text" name="applicant" placeholder="Search by applicant, company, or inventor name..." required />
      <button type="submit">
        Find patents
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </button>
    </form>
  </div>

  <!-- Screenshot mosaic — overlapping fan layout -->
  <div class="hero-mosaic">
    <div class="mosaic-stage">
      <div class="m-card m-1"><img src={`${import.meta.env.BASE_URL}screenshots/slide-1.png`} alt="SimpleIP Patents" loading="lazy" /></div>
      <div class="m-card m-2"><img src={`${import.meta.env.BASE_URL}screenshots/slide-2.png`} alt="SimpleIP Families" loading="lazy" /></div>
      <div class="m-card m-3"><img src={`${import.meta.env.BASE_URL}screenshots/slide-3.png`} alt="SimpleIP Search" loading="lazy" /></div>
      <div class="m-card m-4"><img src={`${import.meta.env.BASE_URL}screenshots/slide-4.png`} alt="SimpleIP Monitoring" loading="lazy" /></div>
      <div class="m-card m-5"><img src={`${import.meta.env.BASE_URL}screenshots/slide-5.png`} alt="SimpleIP Reports" loading="lazy" /></div>
    </div>
  </div>
</section>

<style>
  /* ============================
     HERO — Clean white section
     ============================ */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: #ffffff;
    padding: 160px 0 0;
    overflow: hidden;
  }

  /* ---------- Content ---------- */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 0 24px;
  }

  /* Badge pill */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 100px;
    background: #ffffff;
    border: 1px solid var(--border);
    font-size: 14px;
    font-weight: 600;
    color: var(--headline);
    margin-bottom: 28px;
  }

  /* Heading */
  h1 {
    font-size: clamp(38px, 5.5vw, 64px);
    font-weight: 900;
    color: var(--headline);
    letter-spacing: -2.5px;
    line-height: 1.08;
    margin-bottom: 18px;
  }

  /* Subtitle */
  .hero-sub {
    font-size: 18px;
    color: var(--body);
    max-width: 540px;
    margin: 0 auto 36px;
    line-height: 1.6;
  }

  /* Search bar */
  .hero-search {
    display: flex;
    max-width: 680px;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 6px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    transition: border-color 0.4s, box-shadow 0.4s;
  }
  .hero-search:focus-within {
    border-color: var(--primary);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06), 0 0 0 3px rgba(26, 77, 92, 0.1);
  }

  .hero-search input {
    flex: 1;
    padding: 16px 20px;
    border: none;
    outline: none;
    font-size: 15px;
    background: transparent;
    color: var(--headline);
    min-width: 0;
  }
  .hero-search input::placeholder {
    color: var(--body);
    opacity: 0.5;
  }

  .hero-search button {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border: none;
    border-radius: 12px;
    background: #0F2C35;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .hero-search button:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(15, 44, 53, 0.25);
  }
  .hero-search button:active {
    transform: translateY(0);
  }

  /* ============================
     MOSAIC — Cinematic fan spread
     ============================ */
  .hero-mosaic {
    margin-top: 48px;
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-bottom: 40px;
  }
  /* Edge fades */
  .hero-mosaic::before,
  .hero-mosaic::after {
    content: '';
    position: absolute; top: 0; bottom: 0; width: 200px;
    z-index: 2; pointer-events: none;
  }
  .hero-mosaic::before { left: 0; background: linear-gradient(to right, #ffffff, transparent); }
  .hero-mosaic::after { right: 0; background: linear-gradient(to left, #ffffff, transparent); }

  /* Stage — horizontal layout with perspective */
  .mosaic-stage {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 24px;
    padding: 32px 60px 48px;
    perspective: 2000px;
  }

  /* Each card */
  .m-card {
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--border);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
  }
  .m-card img { width: 100%; display: block; }

  /* Card sizes and transforms — fan effect */
  .m-1 {
    width: 300px;
    transform: rotate(-3deg) translateY(32px);
    box-shadow: -8px 12px 40px rgba(0,0,0,0.08);
  }
  .m-2 {
    width: 340px;
    transform: rotate(-1.5deg) translateY(12px);
    box-shadow: -4px 16px 48px rgba(0,0,0,0.1);
    z-index: 1;
  }
  .m-3 {
    width: 380px;
    transform: rotate(0deg) translateY(0);
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    z-index: 2;
  }
  .m-4 {
    width: 340px;
    transform: rotate(1.5deg) translateY(12px);
    box-shadow: 4px 16px 48px rgba(0,0,0,0.1);
    z-index: 1;
  }
  .m-5 {
    width: 300px;
    transform: rotate(3deg) translateY(32px);
    box-shadow: 8px 12px 40px rgba(0,0,0,0.08);
  }

  /* Hover — cards lift slightly */
  .m-card:hover {
    transform: rotate(0deg) translateY(-4px) scale(1.03);
    box-shadow: 0 24px 64px rgba(0,0,0,0.14);
    z-index: 5;
  }

  /* Bottom fade — screenshots fade into the page */
  .hero-mosaic .mosaic-stage {
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero { padding: 120px 0 0; }
    h1 { letter-spacing: -1.8px; }
    .hero-sub { font-size: 15px; }
    .hero-search { flex-direction: column; margin: 0 20px; }
    .hero-search input { width: 100%; }
    .hero-search button { width: 100%; justify-content: center; }
    .mosaic-stage { gap: 14px; padding: 24px 20px 40px; }
    .m-1 { width: 200px; transform: rotate(-2deg) translateY(20px); }
    .m-2 { width: 230px; transform: rotate(-1deg) translateY(8px); }
    .m-3 { width: 260px; }
    .m-4 { width: 230px; transform: rotate(1deg) translateY(8px); }
    .m-5 { width: 200px; transform: rotate(2deg) translateY(20px); }
  }

  @media (max-width: 480px) {
    .hero { padding: 100px 0 0; }
    .hero-badge { font-size: 12px; padding: 6px 14px; }
    .m-1, .m-5 { display: none; }
    .mosaic-stage { gap: 10px; }
    .m-2 { width: 180px; }
    .m-3 { width: 220px; }
    .m-4 { width: 180px; }
  }
</style>

<script>
  // Search form handler
  document.getElementById('heroSearchForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input[name="applicant"]') as HTMLInputElement;
    const q = input?.value.trim();
    if (!q) return;
    const base = import.meta.env.BASE_URL;
    window.location.href = `${base}register?company=${encodeURIComponent(q)}`;
  });
</script>
