---
const slideImages = [1, 2, 3, 4, 5];
const slides = [...slideImages, ...slideImages, ...slideImages, ...slideImages, ...slideImages];
---
<section class="hero">
  <!-- Layered background -->
  <div class="hero-bg">
    <div class="hero-noise"></div>
    <div class="hero-glow glow-1"></div>
    <div class="hero-glow glow-2"></div>
    <div class="hero-glow glow-3"></div>
    <div class="hero-glow glow-4"></div>
    <div class="hero-grid"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-h1">
      <span class="h1-line">Oversee Your Patents with</span>
      <span class="gradient-text">Intelligent IP Data</span>
    </h1>
    <p class="hero-sub">
      All your patents. One holistic view.<br class="hide-mobile"/>
      <span class="sub-muted">Monitor competitors, analyze landscapes, and manage IP — in seconds.</span>
    </p>
    <form class="hero-search-bar" id="heroSearchForm">
      <div class="search-select">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="14" height="14" rx="2"/><path d="M3 8h14"/></svg>
        <span>Company</span>
        <svg class="chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
      </div>
      <div class="search-divider"></div>
      <div class="search-input-wrap">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="9" r="6"/><path d="M14 14l3 3"/></svg>
        <input type="text" name="applicant" placeholder="Enter a company name" required />
      </div>
      <button type="submit" class="search-btn">
        Get insights
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 2l2 4 4 1-3 3 1 4-4-2-4 2 1-4-3-3 4-1z"/></svg>
      </button>
    </form>
  </div>

  <!-- Carousel -->
  <div class="carousel" id="carousel">
    <div class="carousel-stage">
      <div class="carousel-track" id="carouselTrack">
        {slides.map((num, i) => (
          <div class="c-card" data-index={i}>
            <div class="c-card-inner">
              <div class="c-chrome">
                <div class="c-dots"><i></i><i></i><i></i></div>
                <div class="c-url">
                  <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="4" cy="4" r="3"/><path d="M6.5 6.5L8.5 8.5"/></svg>
                  app.simpleip.com
                </div>
              </div>
              <div class="c-img-wrap">
                <img src={`${import.meta.env.BASE_URL}screenshots/slide-${num}.png`} alt={`SimpleIP — ${num}`} class="c-img" loading="lazy" />
              </div>
            </div>
            <!-- Glow ring on active -->
            <div class="c-glow-ring"></div>
          </div>
        ))}
      </div>
    </div>
    <!-- Minimal pagination -->
    <div class="c-pag" id="cPag">
      {slideImages.map((_, i) => (
        <button class={`c-dot${i === 0 ? ' on' : ''}`} data-i={i}><span></span></button>
      ))}
    </div>
  </div>
</section>

<style>
  /* ============================
     HERO — Premium dark section
     ============================ */
  .hero {
    position: relative; display: flex; flex-direction: column;
    align-items: center; text-align: center;
    background: #050711;
    padding: 150px 0 64px;
    overflow: hidden;
    min-height: 100dvh;
  }

  /* ---------- Background layers ---------- */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  /* Film grain */
  .hero-noise {
    position: absolute; inset: -50%; z-index: 1;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.025;
    mix-blend-mode: overlay;
  }

  .hero-glow {
    position: absolute; border-radius: 50%; filter: blur(100px);
    animation: gFloat 10s ease-in-out infinite alternate;
  }
  .glow-1 {
    width: 1100px; height: 900px; top: -350px; left: 50%; transform: translateX(-50%);
    background: radial-gradient(circle, rgba(59, 91, 219, 0.14) 0%, transparent 65%);
  }
  .glow-2 {
    width: 700px; height: 700px; top: 5%; right: -250px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.09) 0%, transparent 65%);
    animation-delay: -3s; animation-duration: 12s;
  }
  .glow-3 {
    width: 600px; height: 600px; bottom: -5%; left: -200px;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.06) 0%, transparent 65%);
    animation-delay: -6s; animation-duration: 14s;
  }
  .glow-4 {
    width: 400px; height: 400px; top: 50%; left: 50%; transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(59, 91, 219, 0.06) 0%, transparent 60%);
    animation-delay: -1.5s; animation-duration: 8s;
  }
  @keyframes gFloat {
    0% { transform: translateX(-50%) translateY(0) scale(1); }
    100% { transform: translateX(-50%) translateY(25px) scale(1.03); }
  }

  /* Grid */
  .hero-grid {
    position: absolute; inset: 0; z-index: 2;
    background-image:
      linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 55% 45% at 50% 35%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 55% 45% at 50% 35%, black, transparent);
  }

  /* Vignette */
  .hero-vignette {
    position: absolute; inset: 0; z-index: 3;
    background: radial-gradient(ellipse 70% 60% at 50% 40%, transparent 50%, #050711 100%);
  }

  /* ---------- Content ---------- */
  .hero-content {
    position: relative; z-index: 4; max-width: 820px;
    margin-bottom: 52px; padding: 0 24px;
  }

  /* Eyebrow badge */
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 7px 18px 7px 12px;
    border-radius: 100px;
    background: linear-gradient(135deg, rgba(59,91,219,0.1), rgba(139,92,246,0.06));
    border: 1px solid rgba(59,91,219,0.12);
    margin-bottom: 28px;
    animation: fadeDown 0.5s ease both;
    backdrop-filter: blur(8px);
  }
  .eyebrow-pulse {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 0 0 rgba(59,91,219,0.5);
    animation: ePulse 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes ePulse {
    0% { box-shadow: 0 0 0 0 rgba(59,91,219,0.5); }
    70% { box-shadow: 0 0 0 8px rgba(59,91,219,0); }
    100% { box-shadow: 0 0 0 0 rgba(59,91,219,0); }
  }
  .eyebrow-text {
    font-size: 12.5px; font-weight: 600; color: rgba(255,255,255,0.65);
    letter-spacing: 0.4px;
  }

  /* Heading */
  .hero-h1 {
    display: flex; flex-direction: column; gap: 2px;
    font-size: clamp(36px, 5.2vw, 70px); font-weight: 800;
    line-height: 1.06; letter-spacing: -2.5px;
    margin-bottom: 20px;
    animation: fadeDown 0.6s 0.08s ease both;
  }
  .h1-line { color: white; }
  .gradient-text {
    background: linear-gradient(135deg, #F97316 0%, #EC4899 35%, #8B5CF6 70%, #3B5BDB 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    background-size: 200% 200%;
    animation: gradShift 6s ease-in-out infinite alternate;
  }
  @keyframes gradShift {
    0% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  /* Subtitle */
  .hero-sub {
    font-size: 18px; color: rgba(255,255,255,0.55); margin-bottom: 40px;
    animation: fadeDown 0.6s 0.16s ease both;
    line-height: 1.75; letter-spacing: 0.1px;
  }
  .sub-muted { color: rgba(255,255,255,0.35); }
  .hide-mobile { display: inline; }

  /* Search bar */
  .hero-search-bar {
    display: flex; align-items: center; max-width: 620px; margin: 0 auto;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; padding: 6px; gap: 0;
    backdrop-filter: blur(24px);
    box-shadow:
      0 1px 0 0 rgba(255,255,255,0.06) inset,
      0 8px 40px rgba(0,0,0,0.3);
    animation: fadeDown 0.6s 0.24s ease both;
    transition: border-color 0.4s, box-shadow 0.4s;
  }
  .hero-search-bar:focus-within {
    border-color: rgba(59,91,219,0.35);
    box-shadow:
      0 1px 0 0 rgba(255,255,255,0.06) inset,
      0 8px 40px rgba(0,0,0,0.3),
      0 0 0 4px rgba(59,91,219,0.1);
  }
  .search-select {
    display: flex; align-items: center; gap: 8px; padding: 12px 16px;
    color: rgba(255,255,255,0.65); font-size: 13.5px; font-weight: 500;
    cursor: pointer; white-space: nowrap;
  }
  .search-select svg { width: 16px; height: 16px; color: rgba(255,255,255,0.35); }
  .search-select .chevron { width: 10px; height: 10px; }
  .search-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.07); flex-shrink: 0; }
  .search-input-wrap {
    display: flex; align-items: center; gap: 10px; flex: 1; padding: 12px 16px;
  }
  .search-input-wrap svg { width: 16px; height: 16px; color: rgba(255,255,255,0.25); flex-shrink: 0; }
  .search-input-wrap input {
    flex: 1; border: none; outline: none; background: transparent;
    font-size: 13.5px; color: white; font-weight: 400;
  }
  .search-input-wrap input::placeholder { color: rgba(255,255,255,0.2); }
  .search-btn {
    display: flex; align-items: center; gap: 7px;
    padding: 11px 22px; border: none; border-radius: 11px; cursor: pointer;
    background: linear-gradient(135deg, #F97316, #EF4444);
    color: white; font-size: 13.5px; font-weight: 700; white-space: nowrap;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s;
    box-shadow: 0 2px 16px rgba(249,115,22,0.3);
  }
  .search-btn svg { width: 14px; height: 14px; }
  .search-btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 32px rgba(249,115,22,0.4);
  }
  .search-btn:active { transform: translateY(0) scale(0.98); }

  /* ============================
     CAROUSEL — Infinite smooth
     ============================ */
  .carousel {
    position: relative; z-index: 4; width: 100%;
    animation: fadeUp 0.8s 0.35s ease both;
  }
  .carousel-stage {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .carousel-track {
    display: flex; align-items: center;
    gap: 14px; padding: 36px 0 20px;
    will-change: transform;
  }

  /* Cards */
  .c-card {
    flex-shrink: 0; width: 380px;
    position: relative;
    perspective: 1200px;
  }
  .c-card-inner {
    height: 290px;
    border-radius: 16px; overflow: hidden;
    background: #0c0f22;
    border: 1px solid rgba(255,255,255,0.04);
    transform-origin: center center;
    will-change: transform, opacity;
    transition:
      transform 1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.6s ease,
      box-shadow 1s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.6s ease;
  }

  /* Glow ring behind active card */
  .c-glow-ring {
    position: absolute; inset: -14px; z-index: -1;
    border-radius: 26px;
    background: radial-gradient(ellipse at 50% 60%, rgba(59,91,219,0.14), transparent 70%);
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
  }

  /* Chrome */
  .c-chrome {
    height: 36px; display: flex; align-items: center; gap: 12px; padding: 0 14px;
    background: rgba(255,255,255,0.015);
    border-bottom: 1px solid rgba(255,255,255,0.035);
  }
  .c-dots { display: flex; gap: 5px; }
  .c-dots i {
    width: 8px; height: 8px; border-radius: 50%; display: block;
    font-style: normal;
  }
  .c-dots i:nth-child(1) { background: #ff5f57; }
  .c-dots i:nth-child(2) { background: #febc2e; }
  .c-dots i:nth-child(3) { background: #28c840; }
  .c-url {
    display: flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 5px;
    background: rgba(255,255,255,0.025);
    font-size: 10.5px; color: rgba(255,255,255,0.18);
    font-weight: 500; letter-spacing: 0.2px;
  }
  .c-url svg { width: 9px; height: 9px; color: rgba(255,255,255,0.12); }

  .c-img-wrap { overflow: hidden; height: calc(100% - 36px); }
  .c-img {
    width: 100%; height: 100%; display: block;
    object-fit: cover; object-position: top left;
  }

  /* ---- Distance-based states with 3D perspective ---- */
  /* JS sets --rot and --tz as inline styles for smooth per-card 3D */
  .c-card[data-state="active"] .c-card-inner {
    transform: scale(1.08) translateZ(40px);
    opacity: 1;
    border-color: rgba(59, 91, 219, 0.25);
    box-shadow:
      0 0 0 1px rgba(59, 91, 219, 0.06),
      0 24px 70px -10px rgba(59, 91, 219, 0.2),
      0 50px 120px -20px rgba(0, 0, 0, 0.55);
  }
  .c-card[data-state="active"] .c-glow-ring { opacity: 1; }
  .c-card[data-state="active"] .c-chrome {
    background: rgba(255,255,255,0.03);
  }

  .c-card[data-state="near-left"] .c-card-inner {
    transform: scale(0.95) rotateY(8deg) translateX(20px);
    opacity: 0.7;
    box-shadow: -15px 20px 50px rgba(0,0,0,0.35);
  }
  .c-card[data-state="near-right"] .c-card-inner {
    transform: scale(0.95) rotateY(-8deg) translateX(-20px);
    opacity: 0.7;
    box-shadow: 15px 20px 50px rgba(0,0,0,0.35);
  }

  .c-card[data-state="far-left"] .c-card-inner {
    transform: scale(0.88) rotateY(14deg) translateX(40px);
    opacity: 0.35;
    box-shadow: -10px 15px 30px rgba(0,0,0,0.25);
  }
  .c-card[data-state="far-right"] .c-card-inner {
    transform: scale(0.88) rotateY(-14deg) translateX(-40px);
    opacity: 0.35;
    box-shadow: 10px 15px 30px rgba(0,0,0,0.25);
  }

  .c-card[data-state="hidden"] .c-card-inner {
    transform: scale(0.82) rotateY(18deg);
    opacity: 0.08;
  }

  /* Pagination */
  .c-pag {
    display: flex; justify-content: center; gap: 8px;
    position: relative; z-index: 6; padding: 20px 0 0;
  }
  .c-dot {
    width: 8px; height: 8px; border-radius: 50%;
    border: none; padding: 0; cursor: pointer;
    background: rgba(255,255,255,0.1);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative; overflow: hidden;
  }
  .c-dot span {
    position: absolute; inset: 0; border-radius: inherit;
    background: linear-gradient(135deg, #3B5BDB, #8B5CF6);
    transform: scale(0); opacity: 0;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .c-dot.on {
    width: 30px; border-radius: 4px;
    background: rgba(59,91,219,0.12);
    box-shadow: 0 0 20px rgba(59,91,219,0.25);
  }
  .c-dot.on span { transform: scale(1); opacity: 1; }
  .c-dot:hover:not(.on) {
    background: rgba(255,255,255,0.18);
    transform: scale(1.2);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .c-card { width: 320px; }
    .c-card-inner { height: 250px; }
    .carousel-track { gap: 22px; }
  }
  @media (max-width: 768px) {
    .hero { padding: 120px 0 48px; }
    .hero-content { margin-bottom: 36px; }
    .c-card { width: 270px; }
    .c-card-inner { height: 215px; }
    .carousel-track { gap: 16px; }
    .hero-search-bar { flex-direction: column; gap: 0; margin: 0 20px; }
    .search-select { justify-content: center; }
    .search-divider { width: 88%; height: 1px; }
    .search-input-wrap { width: 100%; }
    .search-btn { width: 100%; justify-content: center; }
    .hide-mobile { display: none; }
    .sub-muted { display: block; margin-top: 4px; }
    .carousel-stage {
      mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    }
  }
  @media (max-width: 480px) {
    .hero { padding: 100px 0 36px; min-height: auto; }
    .hero-h1 { letter-spacing: -1.8px; }
    .hero-sub { font-size: 14.5px; margin-bottom: 28px; line-height: 1.6; }
    .hero-eyebrow { font-size: 11.5px; margin-bottom: 20px; padding: 6px 14px 6px 10px; }
    .c-card { width: 230px; }
    .c-card-inner { height: 175px; }
    .carousel-track { gap: 12px; }
    .c-glow-ring { display: none; }
    .c-dot { width: 6px; height: 6px; }
    .c-dot.on { width: 22px; }
  }
  @media (min-width: 1440px) {
    .c-card { width: 440px; }
    .c-card-inner { height: 340px; }
    .carousel-track { gap: 32px; }
    .carousel-stage {
      mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
    }
  }
  @media (min-width: 1920px) {
    .c-card { width: 520px; }
    .c-card-inner { height: 400px; }
    .carousel-track { gap: 38px; }
  }
</style>

<script>
  // Search
  document.getElementById('heroSearchForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input[name="applicant"]') as HTMLInputElement;
    const q = input?.value.trim();
    if (!q) return;
    window.location.href = `/register?company=${encodeURIComponent(q)}`;
  });

  // ===== Infinite carousel — rAF driven =====
  const track = document.getElementById('carouselTrack') as HTMLElement;
  const cards = Array.from(document.querySelectorAll('.c-card')) as HTMLElement[];
  const dots = Array.from(document.querySelectorAll('.c-dot')) as HTMLElement[];
  const stage = document.querySelector('.carousel-stage') as HTMLElement;

  const REAL = 5;
  const BASE_SPEED = 1.2;

  let pos = 0;
  let speed = BASE_SPEED;
  let speedTarget = BASE_SPEED;
  let setW = 0;
  let cW = 0;
  let gap = 28;
  let prev = 0;

  function measure() {
    cW = cards[0].offsetWidth;
    gap = parseFloat(getComputedStyle(track).gap) || 28;
    setW = REAL * (cW + gap);
  }

  function states() {
    const cx = stage.offsetWidth / 2;
    let best = Infinity;
    let bestR = 0;

    for (let i = 0; i < cards.length; i++) {
      const x = -pos + i * (cW + gap) + cW / 2;
      const d = Math.abs(x - cx);
      const n = d / (cW * 0.55);
      const isLeft = x < cx;

      let s: string;
      if (n < 0.65) s = 'active';
      else if (n < 1.7) s = isLeft ? 'near-left' : 'near-right';
      else if (n < 3) s = isLeft ? 'far-left' : 'far-right';
      else s = 'hidden';

      const c = cards[i];
      if (c.dataset.state !== s) c.dataset.state = s;

      if (d < best) { best = d; bestR = i % REAL; }
    }

    for (let i = 0; i < dots.length; i++) {
      dots[i].classList.toggle('on', i === bestR);
    }
  }

  function frame(t: number) {
    if (!prev) prev = t;
    const dt = Math.min(t - prev, 33);
    prev = t;

    // Exponential ease toward target speed
    speed += (speedTarget - speed) * 0.06;
    pos += speed * (dt / 16.67);

    // Wrap
    if (pos >= setW * 3) pos -= setW;
    if (pos < setW) pos += setW;

    track.style.transform = `translate3d(${-pos}px,0,0)`;
    states();
    requestAnimationFrame(frame);
  }

  // Init
  measure();
  pos = setW * 2 - stage.offsetWidth / 2 + cW / 2;
  requestAnimationFrame(frame);

  // Interactions
  stage.addEventListener('mouseenter', () => { speedTarget = 0.12; });
  stage.addEventListener('mouseleave', () => { speedTarget = BASE_SPEED; });

  let tx = 0, tp = 0;
  stage.addEventListener('touchstart', (e) => {
    speedTarget = 0; speed = 0;
    tx = e.changedTouches[0].clientX; tp = pos;
  }, { passive: true });
  stage.addEventListener('touchmove', (e) => {
    pos = tp + (tx - e.changedTouches[0].clientX) * 1.2;
  }, { passive: true });
  stage.addEventListener('touchend', () => { speedTarget = BASE_SPEED; }, { passive: true });

  dots.forEach((d, i) => d.addEventListener('click', () => {
    pos = (REAL * 2 + i) * (cW + gap) - stage.offsetWidth / 2 + cW / 2;
  }));

  cards.forEach((c, i) => c.addEventListener('click', () => {
    pos = i * (cW + gap) - stage.offsetWidth / 2 + cW / 2;
  }));

  window.addEventListener('resize', () => { measure(); });
</script>
