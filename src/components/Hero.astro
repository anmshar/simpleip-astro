---
---
<section class="hero">
  <!-- Ambient orb blobs -->
  <div class="hero-orb orb-1"></div>
  <div class="hero-orb orb-2"></div>
  <div class="hero-orb orb-3"></div>
  <!-- Dot grid -->
  <div class="hero-dot-grid"></div>

  <div class="hero-content">
    <div class="hero-badge" style="animation: fadeUp 0.5s var(--ease-out) 0.04s both;">
      <span class="badge-dot"></span>
      Get started today · No credit card needed
    </div>
    <h1 style="animation: fadeUp 0.6s var(--ease-out) 0.14s both;">
      Manage your IP with ease.<br/><span class="h1-teal">AI-powered, expert-backed.</span>
    </h1>
    <p class="hero-sub" style="animation: fadeUp 0.6s var(--ease-out) 0.24s both;">The first IP workspace that gives growing companies the visibility, analytics and services they need to manage their IP and grow with it, for free.</p>
    <form class="hero-search" id="heroSearchForm" style="animation: fadeUp 0.6s var(--ease-out) 0.34s both;">
      <div class="search-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8fa4b0" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </div>
      <label for="heroSearchInput" class="sr-only">Company or applicant name</label>
      <input type="text" name="applicant" id="heroSearchInput" placeholder="Type your company name" aria-label="Company or applicant name" autocomplete="off" />
      <button type="submit">
        Find patents
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </button>
    </form>

    <!-- Search helper text -->
    <p class="search-helper" style="animation: fadeUp 0.6s var(--ease-out) 0.44s both;">We bring your patents in seconds to a portfolio view.</p>

    <!-- Trust row -->
    <div class="hero-trust" style="animation: fadeUp 0.6s var(--ease-out) 0.54s both;">
      <div class="hero-trust-item"><span class="green-dot"></span> 150M+ patents available</div>
      <span class="trust-dot">·</span>
      <div class="hero-trust-item"><span class="green-dot"></span> Worldwide coverage</div>
      <span class="trust-dot">·</span>
      <div class="hero-trust-item"><span class="green-dot"></span> Portfolio ready in seconds</div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background-color: #2963e7;
    background-image:
      linear-gradient(180deg, rgba(5, 24, 80, 0.28) 0%, rgba(5, 24, 80, 0.10) 55%, rgba(5, 24, 80, 0.00) 100%),
      url('/hero-banner.webp');
    background-repeat: no-repeat, no-repeat;
    background-size: cover, cover;
    background-position: center, center;
    padding: 160px 0 96px;
    overflow: hidden;
  }

  /* Orbs & dot-grid hidden on blue banner background */
  .hero-orb,
  .hero-dot-grid { display: none; }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 800px; padding: 0 24px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 18px; border-radius: 100px;
    background: #ffffff; border: 1.5px solid #e2eaee;
    font-size: 14px; font-weight: 600; color: var(--headline);
    margin-bottom: 28px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .badge-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17b26a; display: inline-block;
    box-shadow: 0 0 0 3px rgba(23,178,106,0.2);
    animation: pulse 2s ease-in-out infinite;
  }

  /* Heading */
  h1 {
    font-size: clamp(38px, 6vw, 68px);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: 18px;
    text-shadow: 0 2px 24px rgba(5, 24, 80, 0.25);
  }
  .h1-teal { color: #ffffff; }

  .hero-sub {
    font-size: 18px; color: rgba(255, 255, 255, 0.92);
    max-width: 500px; margin: 0 auto 36px; line-height: 1.6;
    text-shadow: 0 1px 12px rgba(5, 24, 80, 0.18);
  }

  /* Search bar */
  .hero-search {
    display: flex; align-items: center;
    max-width: 630px; margin: 0 auto;
    background: #ffffff; border: 2px solid #e2eaee;
    border-radius: 14px; padding: 6px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    transition: border-color 0.4s, box-shadow 0.4s;
    animation: glowPulse 4s ease-in-out infinite;
  }
  .hero-search:focus-within {
    border-color: #004ED8;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 4px rgba(0,78,216,0.10);
    animation: none;
  }
  .search-icon {
    display: flex; align-items: center; justify-content: center;
    padding-left: 16px; flex-shrink: 0;
  }
  .hero-search input {
    flex: 1; padding: 16px 14px; border: none; outline: none;
    font-size: 15px; background: transparent; color: var(--headline); min-width: 0;
  }
  .hero-search input::placeholder { color: #8fa4b0; }
  .hero-search button {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 28px; border: none; border-radius: 10px;
    background: linear-gradient(135deg, #004ED8, #0039A8);
    color: #ffffff; font-size: 15px; font-weight: 700;
    cursor: pointer; white-space: nowrap;
    transition: transform 0.3s, box-shadow 0.3s;
    margin: 0;
  }
  .hero-search button svg { transition: transform 0.3s; }
  .hero-search button:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0, 78, 216, 0.32); }
  .hero-search button:hover svg { transform: translateX(3px); }
  .hero-search button:active { transform: translateY(0); }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* Trust row */
  .hero-trust {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; margin-top: 24px; flex-wrap: wrap;
  }
  .hero-trust-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: #ffffff; font-weight: 500;
  }
  .green-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17b26a; display: inline-block; flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(23, 178, 106, 0.22);
  }
  .trust-dot { color: rgba(255, 255, 255, 0.45); font-size: 18px; }

  /* Metric badges */
  .metric-badges {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; margin-top: 40px; flex-wrap: wrap; padding: 0 24px;
    position: relative; z-index: 2;
  }
  .metric-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 16px; border-radius: 100px;
    background: white; border: 1.5px solid #e2eaee;
    font-size: 12px; font-weight: 500; color: var(--body);
  }
  .mb-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .mb-green { background: #17b26a; }
  .mb-blue { background: #004ed8; }
  .mb-orange { background: #ff6c2d; }


  /* ===== RESPONSIVE ===== */
  @media (max-width: 1280px) {
    .hero-content { max-width: 700px; }
  }

  @media (max-width: 1024px) {
    .hero-content { max-width: 620px; }
  }

  @media (max-width: 768px) {
    .hero { padding: 110px 0 72px; }
    .hero-content { padding: 0 20px; }
    h1 { font-size: clamp(28px, 8vw, 42px); letter-spacing: -0.02em; line-height: 1.12; }
    .h1-teal { white-space: normal !important; }
    .hero-sub { font-size: 15px; margin-bottom: 28px; }
    .hero-badge { font-size: 12px; padding: 5px 14px; margin-bottom: 20px; }
    .hero-search { flex-direction: column; margin: 0 auto; padding: 8px; max-width: 100%; }
    .search-icon { display: none; }
    .hero-search input { width: 100%; padding: 14px 16px; font-size: 16px; }
    .hero-search button { width: 100%; justify-content: center; padding: 14px 20px; min-height: 48px; }
    .hint-chips { gap: 6px; margin-top: 14px; padding: 0 8px; }
    .hint-label { font-size: 12px; }
    .hint-chip { font-size: 12px; padding: 6px 12px; min-height: 36px; display: inline-flex; align-items: center; }
    .hero-trust { flex-direction: column; gap: 8px; margin-top: 20px; }
    .trust-dot { display: none; }
    .hero-trust-item { min-height: 32px; }
    .metric-badges { gap: 8px; margin-top: 28px; padding: 0 16px; }
    .metric-badge { font-size: 11px; padding: 6px 12px; gap: 6px; }
    .hero-orb { display: none; }
    .hero-dot-grid { height: 200px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 100px 0 60px; }
    .hero-content { padding: 0 16px; }
    h1 { font-size: clamp(26px, 7.5vw, 36px); }
    .h1-teal { white-space: normal !important; }
    .hero-sub { font-size: 14px; padding: 0; }
    .hero-badge { font-size: 11px; padding: 4px 12px; }
    .hero-search { margin: 0 auto; padding: 6px; }
    .hero-search input { padding: 12px 14px; font-size: 16px; }
    .hero-search button { padding: 12px 16px; font-size: 14px; min-height: 48px; }
    .metric-badges { flex-direction: column; align-items: center; padding: 0 12px; }
    .metric-badge { max-width: 100%; }
  }

  @media (max-width: 320px) {
    .hero { padding: 92px 0 56px; }
    .hero-content { padding: 0 12px; }
    h1 { font-size: 24px; }
    .hero-badge { font-size: 10px; padding: 4px 10px; gap: 6px; }
    .hero-sub { font-size: 13px; }
    .hero-search { padding: 5px; }
    .hero-search input { padding: 10px 12px; }
    .hero-search button { padding: 10px 14px; font-size: 13px; }
    .hint-chips { gap: 4px; }
    .hint-chip { font-size: 11px; padding: 5px 10px; }
    .metric-badge { font-size: 10px; padding: 5px 10px; }
  }
</style>

<script>
  // Typewriter effect
  const terms = ['Siemens AG', 'Bosch GmbH', 'SAP SE', 'Apple Inc', 'Your company'];
  const input = document.getElementById('heroSearchInput') as HTMLInputElement;
  let termIdx = 0, charIdx = 0, isDeleting = false, isPaused = false;
  let userFocused = false;

  function typewrite() {
    if (userFocused) return;
    const current = terms[termIdx];
    if (!isDeleting) {
      input.placeholder = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        isPaused = true;
        setTimeout(() => { isPaused = false; isDeleting = true; typewrite(); }, 1600);
        return;
      }
      setTimeout(typewrite, 90);
    } else {
      input.placeholder = current.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        isDeleting = false;
        termIdx = (termIdx + 1) % terms.length;
      }
      setTimeout(typewrite, 45);
    }
  }
  typewrite();

  input?.addEventListener('focus', () => {
    userFocused = true;
    input.placeholder = 'Search by company or applicant name...';
  });
  input?.addEventListener('blur', () => {
    if (!input.value) {
      userFocused = false;
      charIdx = 0;
      isDeleting = false;
      typewrite();
    }
  });

  // Hint chips
  document.querySelectorAll('.hint-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const term = (chip as HTMLElement).dataset.term || '';
      input.value = term;
      input.focus();
    });
  });

  // Search form handler
  document.getElementById('heroSearchForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = input?.value.trim();
    if (q) sessionStorage.setItem('sip_q', q);
    openReg(q);
  });

  // Enter key
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const q = input.value.trim();
      if (q) sessionStorage.setItem('sip_q', q);
      openReg(q);
    }
  });
</script>
