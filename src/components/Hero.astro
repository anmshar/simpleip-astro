---
---
<section class="hero">
  <!-- Ambient orb blobs -->
  <div class="hero-orb orb-1"></div>
  <div class="hero-orb orb-2"></div>
  <div class="hero-orb orb-3"></div>
  <!-- Dot grid -->
  <div class="hero-dot-grid"></div>

  <div class="hero-content">
    <div class="hero-badge" style="animation: fadeUp 0.5s var(--ease-out) 0.04s both;">
      <span class="badge-dot"></span>
      Get started today · No credit card needed
    </div>
    <h1 style="animation: fadeUp 0.6s var(--ease-out) 0.14s both;">
      Find your patents.<br/><span class="h1-teal" style="white-space:nowrap;">Take control from day one.</span>
    </h1>
    <p class="hero-sub" style="animation: fadeUp 0.6s var(--ease-out) 0.24s both;">The first AI-native patent workspace for growing companies.</p>
    <form class="hero-search" id="heroSearchForm" style="animation: fadeUp 0.6s var(--ease-out) 0.34s both;">
      <div class="search-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8fa4b0" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </div>
      <input type="text" name="applicant" id="heroSearchInput" placeholder="Siemens AG" autocomplete="off" />
      <button type="submit">
        Find patents
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </button>
    </form>

    <!-- Hint chips -->
    <div class="hint-chips" style="animation: fadeUp 0.6s var(--ease-out) 0.44s both;">
      <span class="hint-label">Try</span>
      <button class="hint-chip" data-term="Siemens AG">Siemens</button>
      <button class="hint-chip" data-term="Bosch GmbH">Bosch</button>
      <button class="hint-chip" data-term="SAP SE">SAP</button>
      <span class="hint-label">or your own company</span>
    </div>

    <!-- Trust row -->
    <div class="hero-trust" style="animation: fadeUp 0.6s var(--ease-out) 0.54s both;">
      <div class="hero-trust-item"><span class="green-dot"></span> No credit card</div>
      <span class="trust-dot">·</span>
      <div class="hero-trust-item"><span class="green-dot"></span> 100M+ patents indexed</div>
      <span class="trust-dot">·</span>
      <div class="hero-trust-item"><span class="green-dot"></span> Always available</div>
      <span class="trust-dot">·</span>
      <div class="hero-trust-item"><span class="green-dot"></span> Ready in 2 minutes</div>
    </div>
  </div>

  <!-- Static metric badges -->
  <div class="metric-badges" style="animation: fadeUp 0.6s var(--ease-out) 0.55s both;">
    <div class="metric-badge"><span class="mb-dot mb-green"></span>248 patents found · Siemens AG</div>
    <div class="metric-badge"><span class="mb-dot mb-blue"></span>14 jurisdictions covered</div>
    <div class="metric-badge"><span class="mb-dot mb-orange"></span>New filing detected · BOSCH AG</div>
    <div class="metric-badge"><span class="mb-dot mb-green"></span>Granted · EP3845432</div>
  </div>

  <!-- Screenshot marquee -->
  <div class="marquee-wrap">
    <div class="marquee-fade-l"></div>
    <div class="marquee-fade-r"></div>
    <div class="marquee-track" id="marqueeTrack">
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-mypatents.png`} alt="My Patents view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-search.png`} alt="Search view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-monitoring.png`} alt="Monitoring view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-landscape.png`} alt="Landscape view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-mypatents.png`} alt="My Patents view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-search.png`} alt="Search view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-monitoring.png`} alt="Monitoring view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-landscape.png`} alt="Landscape view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-mypatents.png`} alt="My Patents view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-search.png`} alt="Search view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-monitoring.png`} alt="Monitoring view" loading="lazy" /></div>
      <div class="marquee-card"><img src={`${import.meta.env.BASE_URL}screenshots/hero-landscape.png`} alt="Landscape view" loading="lazy" /></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: #ffffff;
    padding: 160px 0 0;
    overflow: hidden;
  }

  /* Ambient orb blobs */
  .hero-orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: 0.25; pointer-events: none; z-index: 0;
  }
  .orb-1 {
    width: 400px; height: 400px; top: -50px; left: -100px;
    background: radial-gradient(circle, #264d5a, transparent 70%);
    animation: orbFloat1 20s ease-in-out infinite;
  }
  .orb-2 {
    width: 350px; height: 350px; top: 100px; right: -80px;
    background: radial-gradient(circle, #ff6c2d, transparent 70%);
    animation: orbFloat2 25s ease-in-out infinite;
  }
  .orb-3 {
    width: 300px; height: 300px; bottom: 200px; left: 40%;
    background: radial-gradient(circle, #17b26a, transparent 70%);
    animation: orbFloat3 22s ease-in-out infinite;
  }

  /* Dot grid */
  .hero-dot-grid {
    position: absolute; top: 0; left: 0; right: 0; height: 400px;
    background-image: radial-gradient(circle, rgba(38,77,90,0.08) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4), transparent);
    pointer-events: none; z-index: 0;
  }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 800px; padding: 0 24px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 18px; border-radius: 100px;
    background: #ffffff; border: 1.5px solid #e2eaee;
    font-size: 14px; font-weight: 600; color: var(--headline);
    margin-bottom: 28px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .badge-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17b26a; display: inline-block;
    box-shadow: 0 0 0 3px rgba(23,178,106,0.2);
    animation: pulse 2s ease-in-out infinite;
  }

  /* Heading */
  h1 {
    font-size: clamp(38px, 6vw, 68px);
    font-weight: 800;
    color: #0f1d24;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: 18px;
  }
  .h1-teal { color: #264d5a; }

  .hero-sub {
    font-size: 18px; color: #4a6070;
    max-width: 500px; margin: 0 auto 36px; line-height: 1.6;
  }

  /* Search bar */
  .hero-search {
    display: flex; align-items: center;
    max-width: 630px; margin: 0 auto;
    background: #ffffff; border: 2px solid #e2eaee;
    border-radius: 14px; padding: 6px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    transition: border-color 0.4s, box-shadow 0.4s;
    animation: glowPulse 4s ease-in-out infinite;
  }
  .hero-search:focus-within {
    border-color: #264d5a;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 4px rgba(38,77,90,0.08);
    animation: none;
  }
  .search-icon {
    display: flex; align-items: center; justify-content: center;
    padding-left: 16px; flex-shrink: 0;
  }
  .hero-search input {
    flex: 1; padding: 16px 14px; border: none; outline: none;
    font-size: 15px; background: transparent; color: var(--headline); min-width: 0;
  }
  .hero-search input::placeholder { color: #8fa4b0; }
  .hero-search button {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 28px; border: none; border-radius: 10px;
    background: linear-gradient(135deg, #1a3540, #264d5a);
    color: #ffffff; font-size: 15px; font-weight: 700;
    cursor: pointer; white-space: nowrap;
    transition: transform 0.3s, box-shadow 0.3s;
    margin: 0;
  }
  .hero-search button svg { transition: transform 0.3s; }
  .hero-search button:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(15,44,53,0.25); }
  .hero-search button:hover svg { transform: translateX(3px); }
  .hero-search button:active { transform: translateY(0); }

  /* Hint chips */
  .hint-chips {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; margin-top: 16px; flex-wrap: wrap;
  }
  .hint-label { font-size: 13px; color: #8fa4b0; font-weight: 500; }
  .hint-chip {
    padding: 4px 12px; border-radius: 100px;
    background: #f0f5f7; border: 1px solid #e2eaee;
    font-size: 13px; font-weight: 500; color: var(--body);
    cursor: pointer; transition: all 0.2s;
  }
  .hint-chip:hover { background: #1a3540; color: white; border-color: #1a3540; }

  /* Trust row */
  .hero-trust {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; margin-top: 24px; flex-wrap: wrap;
  }
  .hero-trust-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--body); font-weight: 500;
  }
  .green-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17b26a; display: inline-block; flex-shrink: 0;
  }
  .trust-dot { color: var(--border); font-size: 18px; }

  /* Metric badges */
  .metric-badges {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; margin-top: 40px; flex-wrap: wrap; padding: 0 24px;
    position: relative; z-index: 2;
  }
  .metric-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 16px; border-radius: 100px;
    background: white; border: 1.5px solid #e2eaee;
    font-size: 12px; font-weight: 500; color: var(--body);
  }
  .mb-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .mb-green { background: #17b26a; }
  .mb-blue { background: #004ed8; }
  .mb-orange { background: #ff6c2d; }

  /* ====== MARQUEE ====== */
  .marquee-wrap {
    position: relative; width: 100%; overflow: hidden;
    margin-top: 40px; padding: 20px 0;
  }
  .marquee-fade-l, .marquee-fade-r {
    position: absolute; top: 0; bottom: 0; width: 160px;
    z-index: 2; pointer-events: none;
  }
  .marquee-fade-l { left: 0; background: linear-gradient(to right, #ffffff, transparent); }
  .marquee-fade-r { right: 0; background: linear-gradient(to left, #ffffff, transparent); }

  .marquee-track {
    display: flex; gap: 24px;
    animation: marqueeScroll 50s linear infinite;
    width: max-content;
    will-change: transform;
  }
  .marquee-track:hover { animation-play-state: paused; }

  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% / 3)); }
  }

  .marquee-card {
    flex-shrink: 0; width: 360px;
    border-radius: 14px; overflow: hidden;
    background: white; border: 1px solid #e2eaee;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out), opacity 0.4s;
    cursor: default;
    position: relative;
  }
  .marquee-card::after {
    content: ''; position: absolute; inset: 0;
    border-radius: 14px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.5);
    pointer-events: none;
  }
  .marquee-card:hover {
    transform: scale(1.12) translateY(-8px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.16), 0 0 0 1px rgba(38,77,90,0.08);
    z-index: 5;
  }
  .marquee-track:hover .marquee-card:not(:hover) {
    opacity: 0.6;
    transform: scale(0.97);
  }
  .marquee-card img { width: 100%; display: block; border-radius: 14px; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1280px) {
    .hero-content { max-width: 700px; }
  }

  @media (max-width: 768px) {
    .hero { padding: 110px 0 0; }
    h1 { font-size: clamp(28px, 8vw, 42px); letter-spacing: -0.02em; line-height: 1.12; }
    .h1-teal { white-space: normal !important; }
    .hero-sub { font-size: 15px; margin-bottom: 28px; }
    .hero-badge { font-size: 12px; padding: 5px 14px; margin-bottom: 20px; }
    .hero-search { flex-direction: column; margin: 0 20px; padding: 8px; }
    .search-icon { display: none; }
    .hero-search input { width: 100%; padding: 14px 16px; }
    .hero-search button { width: 100%; justify-content: center; padding: 14px 20px; }
    .hint-chips { gap: 6px; margin-top: 14px; }
    .hint-label { font-size: 12px; }
    .hint-chip { font-size: 12px; padding: 4px 10px; }
    .hero-trust { flex-direction: column; gap: 6px; margin-top: 20px; }
    .trust-dot { display: none; }
    .metric-badges { gap: 6px; margin-top: 28px; }
    .metric-badge { font-size: 10px; padding: 5px 10px; gap: 6px; }
    .marquee-card { width: 260px; }
    .marquee-fade-l, .marquee-fade-r { width: 60px; }
    .hero-orb { display: none; }
    .hero-dot-grid { height: 200px; }
  }

  @media (max-width: 375px) {
    .hero { padding: 96px 0 0; }
    h1 { font-size: 28px; }
    .hero-sub { font-size: 14px; padding: 0 8px; }
    .hero-badge { font-size: 11px; padding: 4px 12px; }
    .hero-search { margin: 0 12px; }
    .metric-badges { flex-direction: column; align-items: center; }
    .marquee-card { width: 200px; }
    .marquee-wrap { margin-top: 24px; }
  }
</style>

<script>
  // Typewriter effect
  const terms = ['Siemens AG', 'Bosch GmbH', 'SAP SE', 'Apple Inc', 'Your company'];
  const input = document.getElementById('heroSearchInput') as HTMLInputElement;
  let termIdx = 0, charIdx = 0, isDeleting = false, isPaused = false;
  let userFocused = false;

  function typewrite() {
    if (userFocused) return;
    const current = terms[termIdx];
    if (!isDeleting) {
      input.placeholder = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        isPaused = true;
        setTimeout(() => { isPaused = false; isDeleting = true; typewrite(); }, 1600);
        return;
      }
      setTimeout(typewrite, 90);
    } else {
      input.placeholder = current.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        isDeleting = false;
        termIdx = (termIdx + 1) % terms.length;
      }
      setTimeout(typewrite, 45);
    }
  }
  typewrite();

  input?.addEventListener('focus', () => {
    userFocused = true;
    input.placeholder = 'Search by company or applicant name...';
  });
  input?.addEventListener('blur', () => {
    if (!input.value) {
      userFocused = false;
      charIdx = 0;
      isDeleting = false;
      typewrite();
    }
  });

  // Hint chips
  document.querySelectorAll('.hint-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const term = (chip as HTMLElement).dataset.term || '';
      input.value = term;
      input.focus();
    });
  });

  // Search form handler
  document.getElementById('heroSearchForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = input?.value.trim();
    if (q) sessionStorage.setItem('sip_q', q);
    openReg(q);
  });

  // Enter key
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const q = input.value.trim();
      if (q) sessionStorage.setItem('sip_q', q);
      openReg(q);
    }
  });
</script>
