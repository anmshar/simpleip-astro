---
const steps = [
  { n: '01', title: 'Search', desc: 'Type any company or applicant name. We instantly search across 100M+ patents worldwide.', color: '#264d5a', iconImg: 'icons/step-search.png' },
  { n: '02', title: 'Select', desc: 'Choose the correct entity from matching results. We confirm the exact applicant for you.', color: '#004ed8', iconImg: 'icons/step-select.png' },
  { n: '03', title: 'Register', desc: 'Create your account in 60 seconds. Business email only. No card, no commitment.', color: '#ff6c2d', iconImg: 'icons/step-register.png' },
  { n: '04', title: 'Your portfolio, live', desc: 'Land directly in your patent portfolio with your original search pre-loaded.', color: '#17b26a', iconImg: 'icons/step-live.png' },
];
---
<section class="how-it-works" id="how-it-works">
  <!-- Dot grid texture -->
  <div class="how-dot-grid"></div>
  <div class="how-inner">
    <div class="reveal">
      <p class="section-label">How it works</p>
      <h2>From search to portfolio in <span class="highlight">4 simple steps</span></h2>
      <p class="how-sub">No technical setup. No credit card. Type your company name and you're in.</p>
    </div>

    <div class="steps-row reveal reveal-delay-1">
      <!-- Circles with connector line -->
      <div class="steps-circles">
        {steps.map((s, i) => (
          <div class={`step-circle-wrap${i === 3 ? ' step-highlight' : ''}`}>
            <div class="step-circle" style={`background: ${s.color};`}>
              <img class="step-icon-img" src={`${import.meta.env.BASE_URL}${s.iconImg}`} alt={s.title} />
            </div>
            {i < 3 && <div class="step-line"></div>}
          </div>
        ))}
      </div>

      <!-- Cards below circles -->
      <div class="steps-cards">
        {steps.map((s, i) => (
          <div class={`step-card${i === 3 ? ' step-card-highlight' : ''}`}>
            <span class={`step-badge${i === 3 ? ' step-badge-green' : ''}`}>{s.n}</span>
            <h4>{s.title}</h4>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="how-cta reveal reveal-delay-2">
      <button class="how-btn" onclick="openReg()">
        Get started
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </button>
      <span class="how-note">60-second setup · No credit card</span>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: 100px 24px; background: var(--white);
    text-align: center; position: relative; overflow: hidden;
  }
  .how-dot-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(38,77,90,0.05) 1px, transparent 1px);
    background-size: 48px 48px; pointer-events: none;
  }
  .how-inner { max-width: 960px; margin: 0 auto; position: relative; }
  .how-it-works h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 800; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 12px;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), #2B7A8C);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .how-sub { font-size: 16px; color: var(--body); max-width: 480px; margin: 0 auto 56px; line-height: 1.7; }

  .steps-row { position: relative; }

  /* Circles row */
  .steps-circles {
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px; gap: 0;
  }
  .step-circle-wrap {
    display: flex; align-items: center; position: relative;
  }
  .step-circle {
    width: 84px; height: 84px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: white;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    cursor: default; position: relative; z-index: 2;
  }
  .step-circle:hover {
    transform: scale(1.1);
    box-shadow: 0 0 0 8px rgba(38,77,90,0.1), 0 12px 32px rgba(0,0,0,0.12);
  }
  .step-icon-img { width: 36px; height: 36px; object-fit: contain; filter: invert(1); }
  .step-line {
    width: 80px; height: 3px;
    background: linear-gradient(90deg, var(--primary), rgba(38,77,90,0.15));
    flex-shrink: 0;
  }
  .step-highlight .step-circle {
    box-shadow: 0 0 0 4px rgba(23,178,106,0.2);
  }

  /* Cards row */
  .steps-cards {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
  }
  .step-card {
    padding: 24px 16px; border-radius: 14px;
    border: 1px solid #e2eaee; background: white;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    cursor: default;
  }
  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
  }
  .step-card-highlight { border-color: #17b26a; }
  .step-badge {
    display: inline-block; padding: 3px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 700; color: var(--primary);
    background: rgba(38,77,90,0.08); margin-bottom: 12px;
  }
  .step-badge-green { color: #17b26a; background: #edfaf4; }
  .step-card h4 { font-size: 16px; font-weight: 800; color: var(--headline); margin-bottom: 8px; }
  .step-card p { font-size: 13px; color: var(--body); line-height: 1.65; }

  .how-cta { display: flex; flex-direction: column; align-items: center; gap: 14px; margin-top: 48px; }
  .how-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 15px 36px; border-radius: 10px;
    background: linear-gradient(135deg, #1a3540, #264d5a);
    color: white; font-size: 15px; font-weight: 700;
    border: none; cursor: pointer;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    box-shadow: 0 4px 16px rgba(26,77,90,0.2);
  }
  .how-btn svg { transition: transform 0.3s; }
  .how-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(26,77,90,0.35); }
  .how-btn:hover svg { transform: translateX(3px); }
  .how-note { font-size: 12px; color: var(--body); opacity: 0.7; }

  @media (max-width: 768px) {
    .how-it-works { padding: 60px 16px; }
    .how-it-works h2 { font-size: 26px; letter-spacing: -1px; }
    .how-sub { font-size: 14px; margin-bottom: 36px; }
    .steps-circles { display: none; }
    .steps-cards { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
    .step-card {
      display: flex; align-items: flex-start; gap: 16px; text-align: left;
      padding: 18px;
    }
    .step-card h4 { font-size: 15px; }
    .step-card p { font-size: 12.5px; }
    .how-cta { margin-top: 36px; }
    .how-btn { padding: 14px 28px; font-size: 14px; }
  }

  @media (max-width: 375px) {
    .how-it-works { padding: 48px 12px; }
    .how-it-works h2 { font-size: 22px; }
    .step-card { padding: 14px; gap: 12px; }
  }
</style>
