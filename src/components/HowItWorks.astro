---
const steps = [
  { n: 1, title: 'Search', desc: 'Enter any company or applicant name into the search bar.', color: '#1A4D5C' },
  { n: 2, title: 'Select', desc: 'Choose the correct entity from the matching results.', color: '#24697D' },
  { n: 3, title: 'Sign up', desc: 'Create your free account in under 60 seconds.', color: '#2B7A8C' },
  { n: 4, title: 'Explore', desc: 'Access your full patent portfolio, analytics and alerts.', color: '#2D8A6E' },
];
---
<section class="how-it-works" id="how-it-works">
  <div class="how-inner">
    <div class="reveal">
      <p class="section-label">How it works</p>
      <h2>From search to portfolio in <span class="highlight">4 simple steps</span></h2>
      <p class="how-sub">No technical setup. No credit card. Just type your applicant name and start exploring.</p>
    </div>
    <div class="steps-row reveal reveal-delay-1">
      {steps.map((s, i) => (
        <div class="step">
          <div class="step-number" style={`background: ${s.color}; box-shadow: 0 8px 24px ${s.color}33;`}>
            {s.n}
          </div>
          {i < steps.length - 1 && <div class="step-connector"></div>}
          <div class="step-text">
            <h4>{s.title}</h4>
            <p>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="how-cta">
      <a href={`${import.meta.env.BASE_URL}register`} class="how-btn">Start free</a>
      <span class="how-note">60-second setup</span>
    </div>
  </div>
</section>

<style>
  .how-it-works { padding: 100px 24px; background: var(--bg-light); text-align: center; }
  .how-inner { max-width: 900px; margin: 0 auto; }
  .how-it-works h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 12px;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), #2B7A8C);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .how-sub { font-size: 16px; color: var(--body); max-width: 480px; margin: 0 auto 56px; line-height: 1.7; }
  .steps-row {
    display: flex; justify-content: center; max-width: 900px; margin: 0 auto 52px;
    position: relative;
  }
  .step {
    flex: 1; position: relative; padding: 0 16px;
  }
  .step-number {
    width: 52px; height: 52px; border-radius: 16px; color: var(--white);
    font-size: 20px; font-weight: 900; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; position: relative; z-index: 2;
    transition: transform 0.3s var(--ease-out);
  }
  .step:hover .step-number { transform: scale(1.1); }
  .step-connector {
    position: absolute; top: 26px; left: calc(50% + 36px); right: calc(-50% + 36px);
    height: 2px; z-index: 1;
    background: linear-gradient(90deg, var(--border), var(--primary-light), var(--border));
    opacity: 0.5;
  }
  .step-text { }
  .step h4 { font-size: 17px; font-weight: 800; color: var(--headline); margin-bottom: 8px; }
  .step p { font-size: 13.5px; color: var(--body); line-height: 1.65; }

  .how-cta { display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .how-btn {
    display: inline-flex; padding: 15px 36px; border-radius: 12px;
    background: var(--primary); color: var(--white); font-size: 15px; font-weight: 700;
    transition: background 0.2s, transform 0.3s var(--ease-out), box-shadow 0.3s;
    box-shadow: 0 4px 16px rgba(26, 77, 92, 0.2);
  }
  .how-btn:hover {
    background: var(--primary-light); transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(26, 77, 92, 0.35);
  }
  .how-note { font-size: 12px; color: var(--body); opacity: 0.7; }

  @media (max-width: 768px) {
    .steps-row { flex-direction: column; gap: 28px; }
    .step-connector { display: none; }
    .step {
      display: flex; align-items: center; gap: 16px; text-align: left;
      padding: 16px 20px; border-radius: 14px;
      background: var(--white); border: 1px solid var(--border);
      box-shadow: 0 2px 8px rgba(27, 37, 89, 0.04);
    }
    .step-number { margin: 0; flex-shrink: 0; width: 44px; height: 44px; font-size: 17px; }
    .step h4 { margin-bottom: 4px; }
  }
</style>
