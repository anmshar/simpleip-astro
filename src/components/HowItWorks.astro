---
const steps = [
  { n: 1, title: 'Search', desc: 'Enter any company or applicant name into the search bar.', color: '#3B5BDB' },
  { n: 2, title: 'Select', desc: 'Choose the correct entity from the matching results.', color: '#8B5CF6' },
  { n: 3, title: 'Sign up', desc: 'Create your free account in under 60 seconds.', color: '#0EA5E9' },
  { n: 4, title: 'Explore', desc: 'Access your full patent portfolio, analytics and alerts.', color: '#22C55E' },
];
---
<section class="how-it-works" id="how-it-works">
  <div class="how-inner">
    <p class="section-label">How it works</p>
    <h2>From search to portfolio in <span class="highlight">4 simple steps</span></h2>
    <p class="how-sub">No technical setup. No credit card. Just type your applicant name and start exploring.</p>
    <div class="steps-row">
      {steps.map((s, i) => (
        <div class="step">
          <div class="step-number" style={`background: ${s.color};`}>
            {s.n}
          </div>
          {i < steps.length - 1 && <div class="step-connector"></div>}
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="how-cta">
      <a href="/register" class="how-btn">Get started free</a>
      <span class="how-note">No credit card required</span>
    </div>
  </div>
</section>

<style>
  .how-it-works { padding: 100px 24px; background: var(--bg-light); text-align: center; }
  .how-inner { max-width: 900px; margin: 0 auto; }
  .how-it-works h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 12px;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--purple));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .how-sub { font-size: 16px; color: var(--body); max-width: 480px; margin: 0 auto 56px; line-height: 1.7; }
  .steps-row {
    display: flex; justify-content: center; max-width: 900px; margin: 0 auto 48px;
    position: relative;
  }
  .step { flex: 1; position: relative; padding: 0 20px; }
  .step-number {
    width: 52px; height: 52px; border-radius: 16px; color: var(--white);
    font-size: 20px; font-weight: 900; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; position: relative; z-index: 2;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }
  .step-connector {
    position: absolute; top: 26px; left: calc(50% + 36px); right: calc(-50% + 36px);
    height: 2px; background: var(--border); z-index: 1;
  }
  .step h4 { font-size: 16px; font-weight: 800; color: var(--headline); margin-bottom: 8px; }
  .step p { font-size: 13px; color: var(--body); line-height: 1.6; }

  .how-cta { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .how-btn {
    display: inline-flex; padding: 14px 32px; border-radius: 12px;
    background: var(--primary); color: var(--white); font-size: 15px; font-weight: 700;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .how-btn:hover {
    background: var(--primary-light); transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(59, 91, 219, 0.3);
  }
  .how-note { font-size: 12px; color: var(--body); }

  @media (max-width: 768px) {
    .steps-row { flex-direction: column; gap: 32px; }
    .step-connector { display: none; }
  }
</style>
