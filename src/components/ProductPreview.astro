---
---
<section class="product-preview" id="solutions">
  <div class="product-preview-inner">
    <p class="section-label">See it in action</p>
    <h2>Your complete patent portfolio, <br/><span class="highlight">visualized instantly.</span></h2>
    <p class="sub">See your patents, monitor competitors, analyze landscapes — all in one place.</p>

    <!-- Tab switcher -->
    <div class="preview-tabs" id="previewTabs">
      <button class="preview-tab active" data-tab="patents">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h14M3 10h14M3 15h10"/></svg>
        My Patents
      </button>
      <button class="preview-tab" data-tab="monitoring">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 7A5 5 0 005 7c0 5.5-2.5 7-2.5 7h15S15 12.5 15 7z"/><path d="M11.5 17a2 2 0 01-3 0"/></svg>
        Monitoring
      </button>
      <button class="preview-tab" data-tab="landscape">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 17V7l4-4 4 5 6-5v14H3z"/></svg>
        Landscape
      </button>
    </div>

    <!-- Patents tab -->
    <div class="dash-mockup tab-content active" id="tab-patents">
      <div class="dash-chrome">
        <div class="chrome-dots"><span class="dash-dot r"></span><span class="dash-dot y"></span><span class="dash-dot g"></span></div>
        <div class="chrome-url">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12"/></svg>
          <span>app.simpleip.com</span>
        </div>
      </div>
      <div class="dash-body">
        <div class="dash-sidebar">
          <div class="dash-sidebar-item active"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 3v5H3"/><circle cx="7" cy="8" r="5"/><path d="M15 15l-3-3"/></svg> My patents</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 6A4 4 0 005 6c0 4.5-2 6-2 6h12S13 10.5 13 6z"/><path d="M10 15a1.5 1.5 0 01-3 0"/></svg> Monitoring</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 15V6l3.5-3 3.5 4 5-4v12H3z"/></svg> Landscape</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="12" height="12" rx="2"/><path d="M3 8h12"/><path d="M8 3v12"/></svg> Smart file upload</div>
        </div>
        <div class="dash-main">
          <div class="dash-topbar">
            <div>
              <h3>Patent families <span class="badge-count">Families: 3</span></h3>
              <p class="dash-subtitle">Manage your patents in one central place</p>
            </div>
            <button class="add-btn">+ Add patents</button>
          </div>
          <!-- Search/filter bar -->
          <div class="filter-bar">
            <div class="filter-search">
              <svg viewBox="0 0 16 16" fill="none" stroke="#94A3B8" stroke-width="1.5"><circle cx="7" cy="7" r="5"/><path d="M14 14l-3.5-3.5"/></svg>
              <span>Search by title, keyword...</span>
            </div>
            <div class="filter-pills">
              <span class="filter-pill">Jurisdiction</span>
              <span class="filter-pill">Status</span>
            </div>
            <div class="filter-sort">Sort by: Priority date, Newest first</div>
          </div>
          <!-- Patent family rows -->
          <div class="patent-family">
            <div class="pf-header">
              <div class="pf-expand">
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2l4 4-4 4"/></svg>
              </div>
              <div class="pf-thumb"></div>
              <div class="pf-info">
                <div class="pf-title">Hybrid measurement gap operation</div>
                <div class="pf-meta">Members: 1 · <span class="active-tag">Active: 1</span></div>
                <div class="pf-date">Priority date: 2021-01-15</div>
              </div>
            </div>
            <div class="pf-table">
              <div class="pf-table-header"><span>Jurisdiction</span><span>Filing Type</span><span>Status</span><span>Application number</span><span>Applicant Name</span></div>
              <div class="pf-table-row">
                <span class="jurisdiction"><span class="flag-us"></span> US</span>
                <span class="filing-type">National</span>
                <span><span class="status-active">Active</span></span>
                <span class="app-num">US202117440444A</span>
                <span>Apple Inc.</span>
              </div>
            </div>
          </div>
          <div class="patent-family collapsed">
            <div class="pf-header">
              <div class="pf-expand"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2l4 4-4 4"/></svg></div>
              <div class="pf-thumb"></div>
              <div class="pf-info">
                <div class="pf-title">Energy-efficient semiconductor process</div>
                <div class="pf-meta">Members: 2 · <span class="active-tag">Active: 2</span></div>
                <div class="pf-date">Priority date: 2022-06-10</div>
              </div>
            </div>
          </div>
          <div class="patent-family collapsed">
            <div class="pf-header">
              <div class="pf-expand"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 2l4 4-4 4"/></svg></div>
              <div class="pf-thumb"></div>
              <div class="pf-info">
                <div class="pf-title">Autonomous navigation control method</div>
                <div class="pf-meta">Members: 3 · <span class="active-tag">Active: 1</span> · <span class="pending-tag">Pending: 2</span></div>
                <div class="pf-date">Priority date: 2023-03-22</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Monitoring tab -->
    <div class="dash-mockup tab-content" id="tab-monitoring">
      <div class="dash-chrome">
        <div class="chrome-dots"><span class="dash-dot r"></span><span class="dash-dot y"></span><span class="dash-dot g"></span></div>
        <div class="chrome-url"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12"/></svg><span>app.simpleip.com/monitoring</span></div>
      </div>
      <div class="dash-body">
        <div class="dash-sidebar">
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 3v5H3"/><circle cx="7" cy="8" r="5"/><path d="M15 15l-3-3"/></svg> My patents</div>
          <div class="dash-sidebar-item active"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 6A4 4 0 005 6c0 4.5-2 6-2 6h12S13 10.5 13 6z"/><path d="M10 15a1.5 1.5 0 01-3 0"/></svg> Monitoring</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 15V6l3.5-3 3.5 4 5-4v12H3z"/></svg> Landscape</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="12" height="12" rx="2"/><path d="M3 8h12"/><path d="M8 3v12"/></svg> Smart file upload</div>
        </div>
        <div class="dash-main monitoring-main">
          <div class="dash-topbar">
            <div>
              <h3>Monitor competitors <span class="powered-tag">Powered by Dennemeyer</span></h3>
              <p class="dash-subtitle">Your monthly update of similar filings in the past 12 months</p>
            </div>
          </div>
          <div class="monitoring-layout">
            <div class="monitoring-left">
              <!-- Key players table -->
              <div class="monitoring-card">
                <div class="monitoring-card-header">
                  <h4>Key players</h4>
                </div>
                <div class="kp-table">
                  <div class="kp-header"><span>Ranking</span><span>Company</span><span>New patents</span><span>Technological areas</span></div>
                  <div class="kp-row"><span class="kp-rank">1</span><span>HUAWEI INVESTMENT AND HOLDING CO LTD</span><span class="kp-count red">74</span><span class="kp-area">Electrical Engineering, Instruments</span></div>
                  <div class="kp-row"><span class="kp-rank">2</span><span>NOKIA OYJ</span><span class="kp-count red">34</span><span class="kp-area">Electrical Engineering</span></div>
                  <div class="kp-row"><span class="kp-rank">3</span><span>QUALCOMM INC</span><span class="kp-count orange">29</span><span class="kp-area">Electrical Engineering, Instruments</span></div>
                  <div class="kp-row"><span class="kp-rank">4</span><span>HONOR DEVICE CO LTD</span><span class="kp-count orange">28</span><span class="kp-area">Electrical Engineering</span></div>
                  <div class="kp-row"><span class="kp-rank">5</span><span>SAMSUNG ELECTRONICS CO LTD</span><span class="kp-count yellow">20</span><span class="kp-area">Electrical Engineering, Instruments</span></div>
                </div>
              </div>
              <!-- Patent activity map placeholder -->
              <div class="monitoring-card">
                <div class="monitoring-card-header"><h4>Patent activity map</h4></div>
                <div class="map-placeholder">
                  <div class="map-dots">
                    <span class="map-dot" style="left:20%;top:30%"></span>
                    <span class="map-dot green" style="left:48%;top:25%"></span>
                    <span class="map-dot" style="left:52%;top:35%"></span>
                    <span class="map-dot red" style="left:30%;top:50%"></span>
                    <span class="map-dot green" style="left:72%;top:40%"></span>
                    <span class="map-dot" style="left:80%;top:30%"></span>
                    <span class="map-dot red" style="left:75%;top:50%"></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="monitoring-right">
              <div class="monthly-card">
                <p class="mc-label">My monthly update</p>
                <div class="mc-number">27</div>
                <p class="mc-sub">New Patents found<br/>from 14 competitors</p>
                <div class="mc-trend">↑ up by 2,400 % compared to last month</div>
                <a class="mc-link">See the 27 patents →</a>
              </div>
              <div class="chart-card">
                <h4>Similar patents over time</h4>
                <p class="chart-legend"><span class="legend-dot"></span> Filed patents (Monthly number)</p>
                <div class="bar-chart">
                  <div class="bar-col"><div class="bar" style="height:30%"></div><span>Apr</span></div>
                  <div class="bar-col"><div class="bar" style="height:20%"></div><span>May</span></div>
                  <div class="bar-col"><div class="bar" style="height:50%"></div><span>Jun</span></div>
                  <div class="bar-col"><div class="bar" style="height:35%"></div><span>Jul</span></div>
                  <div class="bar-col"><div class="bar" style="height:90%"></div><span>Aug</span></div>
                  <div class="bar-col"><div class="bar" style="height:25%"></div><span>Sep</span></div>
                  <div class="bar-col"><div class="bar" style="height:40%"></div><span>Oct</span></div>
                  <div class="bar-col"><div class="bar" style="height:15%"></div><span>Nov</span></div>
                  <div class="bar-col"><div class="bar" style="height:10%"></div><span>Dec</span></div>
                  <div class="bar-col"><div class="bar" style="height:20%"></div><span>Jan</span></div>
                  <div class="bar-col"><div class="bar" style="height:55%"></div><span>Feb</span></div>
                  <div class="bar-col"><div class="bar" style="height:30%"></div><span>Mar</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Landscape tab -->
    <div class="dash-mockup tab-content" id="tab-landscape">
      <div class="dash-chrome">
        <div class="chrome-dots"><span class="dash-dot r"></span><span class="dash-dot y"></span><span class="dash-dot g"></span></div>
        <div class="chrome-url"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M2 6h12"/></svg><span>app.simpleip.com/landscape</span></div>
      </div>
      <div class="dash-body">
        <div class="dash-sidebar">
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 3v5H3"/><circle cx="7" cy="8" r="5"/><path d="M15 15l-3-3"/></svg> My patents</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 6A4 4 0 005 6c0 4.5-2 6-2 6h12S13 10.5 13 6z"/><path d="M10 15a1.5 1.5 0 01-3 0"/></svg> Monitoring</div>
          <div class="dash-sidebar-item active"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 15V6l3.5-3 3.5 4 5-4v12H3z"/></svg> Landscape</div>
          <div class="dash-sidebar-item"><svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="12" height="12" rx="2"/><path d="M3 8h12"/><path d="M8 3v12"/></svg> Smart file upload</div>
        </div>
        <div class="dash-main landscape-main">
          <div class="dash-topbar">
            <div>
              <h3>Competitive landscape <span class="powered-tag">Powered by Dennemeyer</span></h3>
              <p class="dash-subtitle">Your long term patent landscape compared to your competitors based on your portfolio</p>
            </div>
          </div>
          <div class="landscape-grid">
            <div class="ls-card">
              <div class="ls-card-header"><h4>Top competitors</h4><span class="ls-badge neutral">Neutral</span></div>
              <div class="ls-icon-row"><span class="ls-icon">🏢</span></div>
              <p class="ls-card-company">BEIJING XIAOMI, INTEL CORP and QUALCOMM INC</p>
              <p class="ls-card-desc">are the most competitors operating in your field</p>
            </div>
            <div class="ls-card">
              <div class="ls-card-header"><h4>Portfolio age difference</h4><span class="ls-badge neutral">Neutral</span></div>
              <div class="ls-icon-row"><span class="ls-icon">⏱</span></div>
              <p class="ls-card-company">Similar age</p>
              <p class="ls-card-desc">Your patents are on average the similar age as the competition</p>
              <a class="ls-link">See insight →</a>
            </div>
            <div class="ls-card">
              <div class="ls-card-header"><h4>Patent citations</h4><span class="ls-badge red">Red</span></div>
              <div class="ls-icon-row"><span class="ls-icon">📊</span></div>
              <p class="ls-card-company">103% less cited</p>
              <p class="ls-card-desc">Your patents are cited 103% less than the competition</p>
            </div>
            <div class="ls-card">
              <div class="ls-card-header"><h4>Market coverage</h4><span class="ls-badge neutral">Neutral</span></div>
              <div class="ls-icon-row"><span class="ls-icon">🌍</span></div>
              <p class="ls-card-company">Similar coverage</p>
              <p class="ls-card-desc">Your patents cover as many markets as your competition</p>
              <a class="ls-link">See insight →</a>
            </div>
            <div class="ls-card">
              <div class="ls-card-header"><h4>New markets</h4><span class="ls-badge red">Red</span></div>
              <div class="ls-icon-row"><span class="ls-icon">🚀</span></div>
              <p class="ls-card-company">EPO, Korea, Japan, Brazil and Taiwan</p>
              <p class="ls-card-desc">Your competitors are more active than you in these regions</p>
              <a class="ls-link">See insight →</a>
            </div>
            <div class="ls-card">
              <div class="ls-card-header"><h4>Portfolio value</h4><span class="ls-badge neutral">Neutral</span></div>
              <div class="ls-icon-row"><span class="ls-icon">💰</span></div>
              <p class="ls-card-company">No value data</p>
              <p class="ls-card-desc">Value information is not available for this portfolio</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.preview-tab');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`tab-${target}`)?.classList.add('active');
    });
  });
</script>

<style>
  .product-preview { padding: 100px 24px; text-align: center; background: var(--bg-light); }
  .product-preview-inner { max-width: 1100px; margin: 0 auto; }
  .product-preview h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 14px; line-height: 1.2;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--purple));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .sub { font-size: 17px; color: var(--body); max-width: 520px; margin: 0 auto 36px; line-height: 1.7; }

  /* Tabs */
  .preview-tabs {
    display: inline-flex; gap: 4px; padding: 4px; border-radius: 14px;
    background: var(--white); border: 1px solid var(--border); margin-bottom: 32px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .preview-tab {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 10px; border: none;
    background: transparent; font-size: 13px; font-weight: 600;
    color: var(--body); cursor: pointer; transition: all 0.2s;
  }
  .preview-tab svg { width: 16px; height: 16px; }
  .preview-tab.active { background: var(--primary); color: white; }
  .preview-tab:not(.active):hover { background: var(--bg-light); }

  /* Tab content */
  .tab-content { display: none; }
  .tab-content.active { display: block; animation: fadeDown 0.3s ease; }

  /* Browser frame */
  .dash-mockup {
    border-radius: var(--radius-lg); background: var(--white);
    border: 1px solid var(--border); overflow: hidden;
    box-shadow: 0 40px 100px rgba(27, 37, 89, 0.08), 0 0 0 1px rgba(0,0,0,0.02);
    text-align: left;
  }
  .dash-chrome {
    height: 44px; background: var(--bg-lighter); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 16px; padding: 0 20px;
  }
  .chrome-dots { display: flex; gap: 6px; }
  .dash-dot { width: 12px; height: 12px; border-radius: 50%; }
  .dash-dot.r { background: #ff5f56; } .dash-dot.y { background: #ffbd2e; } .dash-dot.g { background: #27c93f; }
  .chrome-url {
    display: flex; align-items: center; gap: 8px; padding: 5px 14px;
    border-radius: 8px; background: var(--white); border: 1px solid var(--border);
    font-size: 12px; color: var(--body);
  }
  .chrome-url svg { width: 13px; height: 13px; }
  .dash-body { display: flex; min-height: 440px; }
  .dash-sidebar {
    width: 180px; border-right: 1px solid var(--border);
    padding: 20px 12px; display: flex; flex-direction: column; gap: 2px;
    flex-shrink: 0;
  }
  .dash-sidebar-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 10px; font-size: 12px;
    color: var(--body); font-weight: 500; white-space: nowrap;
  }
  .dash-sidebar-item svg { width: 16px; height: 16px; flex-shrink: 0; }
  .dash-sidebar-item.active { background: rgba(59, 91, 219, 0.06); color: var(--primary); font-weight: 700; }
  .dash-main { flex: 1; padding: 24px; overflow: hidden; }
  .dash-topbar { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
  .dash-topbar h3 { font-size: 18px; font-weight: 800; color: var(--headline); display: flex; align-items: center; gap: 10px; }
  .dash-subtitle { font-size: 12px; color: var(--body); margin-top: 2px; }
  .badge-count { font-size: 11px; font-weight: 600; padding: 2px 10px; border-radius: 20px; background: var(--bg-light); color: var(--body); }
  .powered-tag { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 4px; background: var(--bg-light); color: var(--body); }
  .add-btn {
    padding: 8px 16px; border-radius: 8px; border: none;
    background: var(--primary); color: white; font-size: 12px; font-weight: 700;
    cursor: pointer; white-space: nowrap;
  }

  /* Filter bar */
  .filter-bar {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
    padding: 8px 0; flex-wrap: wrap;
  }
  .filter-search {
    display: flex; align-items: center; gap: 8px; padding: 7px 14px;
    border-radius: 8px; border: 1px solid var(--border); font-size: 12px; color: #94A3B8;
    flex: 1; min-width: 160px;
  }
  .filter-search svg { width: 14px; height: 14px; flex-shrink: 0; }
  .filter-pills { display: flex; gap: 6px; }
  .filter-pill {
    padding: 6px 12px; border-radius: 8px; border: 1px solid var(--border);
    font-size: 11px; color: var(--body); font-weight: 500;
  }
  .filter-sort { font-size: 11px; color: var(--body); margin-left: auto; white-space: nowrap; }

  /* Patent families */
  .patent-family {
    border: 1px solid var(--border); border-radius: 12px; margin-bottom: 10px;
    overflow: hidden;
  }
  .patent-family.collapsed .pf-table { display: none; }
  .pf-header {
    display: flex; align-items: center; gap: 14px; padding: 16px 18px;
    background: var(--white);
  }
  .pf-expand { width: 18px; height: 18px; color: var(--body); flex-shrink: 0; }
  .pf-expand svg { width: 12px; height: 12px; }
  .pf-thumb { width: 56px; height: 40px; border-radius: 6px; background: var(--bg-light); border: 1px solid var(--border); flex-shrink: 0; }
  .pf-info { flex: 1; min-width: 0; }
  .pf-title { font-size: 13px; font-weight: 700; color: var(--headline); }
  .pf-meta { font-size: 11px; color: var(--body); margin-top: 2px; }
  .active-tag { color: #16A34A; font-weight: 600; }
  .pending-tag { color: #EA580C; font-weight: 600; }
  .pf-date { font-size: 11px; color: var(--body); margin-top: 1px; }
  .pf-table { border-top: 1px solid var(--border); background: var(--bg-lighter); }
  .pf-table-header {
    display: grid; grid-template-columns: 1fr 1fr 0.8fr 1.5fr 1.2fr;
    gap: 8px; padding: 10px 18px; font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.5px; color: var(--body);
    border-bottom: 1px solid var(--border);
  }
  .pf-table-row {
    display: grid; grid-template-columns: 1fr 1fr 0.8fr 1.5fr 1.2fr;
    gap: 8px; padding: 12px 18px; font-size: 12px; color: var(--headline);
    align-items: center;
  }
