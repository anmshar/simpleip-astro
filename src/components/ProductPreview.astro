---
const tabs = [
  { id: 'patents', label: 'My Patents', icon: '<path d="M3 5h14M3 10h14M3 15h10"/>', image: 'screenshot-patents.png' },
  { id: 'monitoring', label: 'Monitoring', icon: '<path d="M15 7A5 5 0 005 7c0 5.5-2.5 7-2.5 7h15S15 12.5 15 7z"/><path d="M11.5 17a2 2 0 01-3 0"/>', image: 'screenshot-monitoring.png' },
  { id: 'landscape', label: 'Landscape', icon: '<path d="M3 17V7l4-4 4 5 6-5v14H3z"/>', image: 'screenshot-landscape.webp' },
];
---
<section class="product-preview" id="solutions">
  <!-- Background images (one per tab, blurred) -->
  {tabs.map((t, i) => (
    <div class={`pp-bg${i === 0 ? ' active' : ''}`} id={`bg-${t.id}`}>
      <img src={`${import.meta.env.BASE_URL}${t.image}`} alt="" aria-hidden="true" loading={i === 0 ? 'eager' : 'lazy'} />
    </div>
  ))}
  <div class="pp-bg-overlay"></div>

  <!-- Foreground content -->
  <div class="pp-content reveal">
    <p class="section-label" style="color: var(--primary);">See it in action</p>
    <h2>Your complete patent portfolio, <br/><span class="highlight">visualized instantly.</span></h2>
    <p class="sub">See your patents, monitor competitors, analyze landscapes — all in one place.</p>

    <div class="preview-tabs" id="previewTabs">
      {tabs.map((t, i) => (
        <button class={`preview-tab${i === 0 ? ' active' : ''}`} data-tab={t.id}>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" set:html={t.icon} />
          {t.label}
        </button>
      ))}
    </div>

    <a href={`${import.meta.env.BASE_URL}register`} class="pp-cta">
      Start free
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.preview-tab');
  const bgs = document.querySelectorAll('.pp-bg');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach(t => t.classList.remove('active'));
      bgs.forEach(b => b.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(`bg-${target}`)?.classList.add('active');
    });
  });
</script>

<style>
  .product-preview {
    position: relative;
    min-height: 85vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 120px 24px;
  }

  /* Background screenshots — blurred, full cover */
  .pp-bg {
    position: absolute; inset: 0; z-index: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .pp-bg.active { opacity: 1; }
  .pp-bg img {
    width: 100%; height: 100%;
    object-fit: contain; object-position: center center;
    display: block;
    filter: blur(3px);
    transform: scale(1);
  }

  /* Overlay — white wash so text is readable */
  .pp-bg-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.72) 50%,
      rgba(255, 255, 255, 0.85) 100%
    );
  }

  /* Foreground content */
  .pp-content {
    position: relative; z-index: 2;
    max-width: 700px;
  }
  .pp-content h2 {
    font-size: clamp(28px, 3.5vw, 44px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 14px; line-height: 1.15;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), #2B7A8C);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .sub {
    font-size: 17px; color: var(--body); max-width: 500px;
    margin: 0 auto 36px; line-height: 1.7;
  }

  /* Tabs */
  .preview-tabs {
    display: inline-flex; gap: 4px; padding: 5px; border-radius: 14px;
    background: rgba(255, 255, 255, 0.9); border: 1px solid var(--border);
    margin-bottom: 28px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    backdrop-filter: blur(8px);
  }
  .preview-tab {
    display: flex; align-items: center; gap: 8px;
    padding: 11px 22px; border-radius: 10px; border: none;
    background: transparent; font-size: 13px; font-weight: 600;
    color: var(--body); cursor: pointer;
    transition: all 0.3s var(--ease-out);
  }
  .preview-tab svg { width: 16px; height: 16px; }
  .preview-tab.active {
    background: var(--primary); color: white;
    box-shadow: 0 4px 12px rgba(26, 77, 92, 0.25);
  }
  .preview-tab:not(.active):hover { background: rgba(255,255,255,0.8); color: var(--headline); }

  /* CTA button */
  .pp-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px; border-radius: 12px;
    background: var(--primary-dark); color: white;
    font-size: 15px; font-weight: 700;
    box-shadow: 0 4px 20px rgba(15, 44, 53, 0.2);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }
  .pp-cta svg { width: 14px; height: 14px; transition: transform 0.3s var(--ease-out); }
  .pp-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(15, 44, 53, 0.3);
  }
  .pp-cta:hover svg { transform: translateX(3px); }

  @media (max-width: 768px) {
    .product-preview { min-height: 60vh; padding: 80px 20px; }
    .preview-tabs { flex-wrap: wrap; }
    .preview-tab { font-size: 12px; padding: 9px 16px; }
  }
</style>
