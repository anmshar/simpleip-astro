---
---
<!-- Announcement bar -->
<div class="announce-bar" id="announceBar">
  <div class="announce-inner">
    <span class="announce-badge">Coming soon</span>
    <span>Ideas. Capture your next invention, assess its potential with AI and fast-track it to expert filing.</span>
    <a href="#" class="announce-link" onclick="event.preventDefault(); openReg();">Explore now →</a>
  </div>
  <button class="announce-close" id="announceClose" aria-label="Close announcement">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4l8 8M12 4l-8 8"/></svg>
  </button>
</div>

<nav class="nav" id="mainNav" aria-label="Primary">
  <div class="nav-inner">
    <a href={import.meta.env.BASE_URL} class="nav-logo">
      <img src={`${import.meta.env.BASE_URL}logo.svg`} alt="SimpleIP" class="nav-logo-img" />
    </a>
    <div class="nav-right">
      <a href="https://app.simpleip.com" class="nav-login" target="_blank" rel="noopener">Log In</a>
      <button class="nav-cta" onclick="openReg()">
        Register now
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </button>
    </div>
  </div>
</nav>
<div id="content-start" tabindex="-1"></div>

<script>
  const nav = document.getElementById('mainNav');
  const hero = document.querySelector('.hero');
  const announceBar = document.getElementById('announceBar');
  const announceClose = document.getElementById('announceClose');

  announceClose?.addEventListener('click', () => {
    announceBar?.classList.add('closed');
    document.body.style.setProperty('--announce-height', '0px');
  });

  const syncNavAppearance = () => {
    nav?.classList.toggle('scrolled', !hero || window.scrollY > 50);
  };
  syncNavAppearance();
  window.addEventListener('scroll', syncNavAppearance);
</script>

<style>
  /* Announcement bar */
  .announce-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 110;
    height: 40px; display: flex; align-items: center; justify-content: center;
    background: #004ED8;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    transition: transform 0.3s, opacity 0.3s;
  }
  .announce-bar.closed { transform: translateY(-100%); opacity: 0; pointer-events: none; }
  .announce-inner {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; color: rgba(255,255,255,0.7);
  }
  .announce-badge {
    padding: 2px 10px; border-radius: 20px;
    background: #ff6c2d; color: white;
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .announce-link { color: rgba(255,255,255,0.9); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .announce-close {
    position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.4);
    width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
  }
  .announce-close svg { width: 14px; height: 14px; }
  .announce-close:hover { color: rgba(255,255,255,0.8); }

  /* Nav — white bg, 62px, just logo + CTA */
  .nav {
    position: fixed; top: 40px; left: 0; right: 0; z-index: 100;
    height: 62px; display: flex; align-items: center; justify-content: center;
    background: #ffffff;
    box-shadow: 0 1px 0 #e2eaee;
    transition: background 0.3s, box-shadow 0.3s, top 0.3s;
  }
  .announce-bar.closed ~ .nav { top: 0; }
  .nav.scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 1px 0 #e2eaee;
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 1200px; padding: 0 32px;
  }
  .nav-logo { display: flex; align-items: center; height: 22px; }
  .nav-logo-img { height: 22px; width: auto; }

  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-login {
    font-size: 14px; font-weight: 600; color: var(--headline, #0f1d24);
    text-decoration: none; padding: 10px 16px; border-radius: 10px;
    transition: background 0.2s, color 0.2s;
  }
  .nav-login:hover { background: rgba(38,77,90,0.06); }
  .nav-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 22px; border-radius: 10px;
    background: #004ED8; color: white;
    font-size: 14px; font-weight: 700;
    border: none; cursor: pointer;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    box-shadow: 0 2px 8px rgba(0, 78, 216, 0.22);
  }
  .nav-cta svg { width: 14px; height: 14px; transition: transform 0.3s; }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0, 78, 216, 0.28); }
  .nav-cta:hover svg { transform: translateX(3px); }

  @media (max-width: 768px) {
    .announce-bar { display: none; }
    .nav { top: 0; }
    .nav-inner { padding: 0 16px; }
    .nav-cta { font-size: 13px; padding: 12px 20px; min-height: 44px; }
  }

  @media (max-width: 375px) {
    .nav-inner { padding: 0 12px; }
    .nav-logo-img { height: 20px; }
    .nav-cta { font-size: 12px; padding: 10px 16px; min-height: 44px; }
  }
</style>
