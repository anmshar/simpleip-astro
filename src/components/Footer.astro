---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo"><img src={`${import.meta.env.BASE_URL}logo.svg`} alt="SimpleIP" class="footer-logo-img" /></div>
        <p class="footer-tagline">Patent intelligence, simplified.</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" aria-label="Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h5>Product</h5>
          <a href="/#solutions">Solutions</a>
          <a href="/#how-it-works">How it works</a>
          <a href="/#features">Features</a>
          <a href={`${import.meta.env.BASE_URL}register`}>Start free</a>
        </div>
        <div class="footer-col">
          <h5>Resources</h5>
          <a href={`${import.meta.env.BASE_URL}docs`}>Documentation</a>
          <a href={`${import.meta.env.BASE_URL}api`}>API Reference</a>
          <a href="https://www.simpleip.com/us/blog" target="_blank" rel="noopener">Blog</a>
          <a href="https://dennemeyer.com" target="_blank" rel="noopener">Dennemeyer.com</a>
        </div>
        <div class="footer-col">
          <h5>Legal</h5>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Use</a>
          <a href="#">Impressum</a>
          <a href="#">GDPR</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Dennemeyer Group. All rights reserved.</span>
      <span class="footer-bottom-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Cookies</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, #0F2C35 0%, #081C22 100%);
    padding: 80px 48px 36px;
    color: rgba(255, 255, 255, 0.4);
    position: relative;
  }
  .footer::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(26, 77, 92, 0.15), transparent);
  }
  .footer-inner { max-width: 1100px; margin: 0 auto; }
  .footer-top {
    display: flex; justify-content: space-between; gap: 64px;
    margin-bottom: 48px; padding-bottom: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .footer-logo { display: flex; align-items: center; }
  .footer-logo-img { height: 22px; width: auto; filter: brightness(0) invert(1); }
  .footer-tagline { font-size: 14px; color: rgba(255, 255, 255, 0.3); margin-top: 10px; line-height: 1.5; }
  .footer-social { display: flex; gap: 10px; margin-top: 22px; }
  .footer-social a {
    width: 38px; height: 38px; border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255, 255, 255, 0.4);
    transition: background 0.3s, color 0.3s, border-color 0.3s, transform 0.3s var(--ease-out);
  }
  .footer-social a:hover {
    background: rgba(26, 77, 92, 0.15); color: rgba(255, 255, 255, 0.9);
    border-color: rgba(26, 77, 92, 0.25); transform: translateY(-2px);
  }
  .footer-social svg { width: 16px; height: 16px; }
  .footer-links { display: flex; gap: 64px; }
  .footer-col h5 {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.25); margin-bottom: 18px;
  }
  .footer-col a {
    display: block; font-size: 14px; color: rgba(255, 255, 255, 0.4);
    padding: 5px 0; transition: color 0.2s, transform 0.3s;
  }
  .footer-col a:hover { color: rgba(255, 255, 255, 0.85); transform: translateX(4px); }
  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; color: rgba(255, 255, 255, 0.2);
  }
  .footer-bottom-links { display: flex; gap: 20px; }
  .footer-bottom-links a { color: rgba(255, 255, 255, 0.2); transition: color 0.2s; }
  .footer-bottom-links a:hover { color: rgba(255, 255, 255, 0.5); }

  @media (max-width: 768px) {
    .footer { padding: 48px 20px 24px; }
    .footer-top { flex-direction: column; gap: 40px; }
    .footer-links { flex-direction: column; gap: 32px; }
    .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
