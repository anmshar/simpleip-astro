          </a>
        </div>
      </div>
      <div class="footer-links">
        <!-- Column 2 — Legal -->
        <div class="footer-col">
          <h5>Legal</h5>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Use</a>
          <a href="#">Impressum</a>
        </div>
        <!-- Column 3 — Links -->
        <div class="footer-col">
          <h5>Links</h5>
          <a href="https://dennemeyer.com" target="_blank" rel="noopener">Dennemeyer.com ↗</a>
          <button class="footer-start-btn" onclick="openReg()">Get started →</button>
