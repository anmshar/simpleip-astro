---
---
<section class="office-banner">
  <img src={`${import.meta.env.BASE_URL}banner-office.webp`} alt="Enterprise office with city skyline at dusk" loading="lazy" />
  <div class="office-banner-overlay"></div>
</section>

<style>
  .office-banner {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
  }
  .office-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .office-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(247, 249, 250, 0.3) 0%,
      transparent 20%,
      transparent 80%,
      rgba(255, 255, 255, 0.3) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .office-banner { height: 200px; }
  }
  @media (max-width: 480px) {
    .office-banner { height: 160px; }
  }
</style>
