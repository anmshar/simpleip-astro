---
---
<section class="office-banner">
  <img src={`${import.meta.env.BASE_URL}banner-office.webp`} alt="Enterprise office with city skyline at dusk" loading="lazy" />
</section>

<style>
  .office-banner {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
  }
  .office-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  @media (max-width: 768px) {
    .office-banner { height: 200px; }
  }
  @media (max-width: 480px) {
    .office-banner { height: 160px; }
  }
</style>
