---
---
<section class="office-banner">
  <img src={`${import.meta.env.BASE_URL}banner-office.webp`} alt="Enterprise office with city skyline at dusk" loading="lazy" />
</section>

<style>
  .office-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 21 / 6;
  }
  .office-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  @media (max-width: 1024px) {
    .office-banner { aspect-ratio: 16 / 5; }
  }
  @media (max-width: 768px) {
    .office-banner { aspect-ratio: 16 / 6; }
  }
  @media (max-width: 479px) {
    .office-banner { aspect-ratio: 16 / 7; }
  }
</style>
