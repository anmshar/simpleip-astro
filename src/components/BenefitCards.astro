---
const cards = [
  {
    color: '#264d5a',
    headline: 'Patent Discovery',
    body: 'Search across 100M+ patents from 80+ global offices instantly. Type any company name and explore their full patent portfolio.',
    illustration: 'illustrations/patent-discovery.png',
  },
  {
    color: '#ff6c2d',
    headline: 'Competitor Monitoring',
    body: 'Get automated alerts when competitors file new patents. Monitor any technology space with real-time intelligence.',
    illustration: 'illustrations/competitor-monitoring.png',
  },
  {
    color: '#004ed8',
    headline: 'Reports & Analytics',
    body: 'Generate board-ready IP reports in one click. Portfolio benchmarks, green patent analysis, and technology landscapes.',
    illustration: 'illustrations/reports-analytics.png',
  },
  {
    color: '#17b26a',
    headline: 'Global Coverage',
    body: 'Access patent data from EPO, USPTO, WIPO, DPMA and 80+ offices worldwide in one unified, searchable platform.',
    illustration: 'illustrations/global-coverage.png',
  },
];
---
<section class="benefits">
  <div class="benefits-inner">
    <div class="benefits-header reveal">
      <p class="section-label">Solutions</p>
      <h2>Everything you need to manage your IP</h2>
      <p class="benefits-sub">Powerful patent intelligence tools trusted by IP professionals, legal teams, and innovators worldwide.</p>
    </div>
    <div class="cards-grid">
      {cards.map((c, i) => (
        <div class={`benefit-card reveal reveal-delay-${i % 4}`} style={`--card-color: ${c.color};`}>
          <div class="card-accent" style={`background: ${c.color};`}></div>
          <div class="card-illustration">
            <img src={`${import.meta.env.BASE_URL}${c.illustration}`} alt={c.headline} loading="lazy" />
          </div>
          <h3>{c.headline}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits { padding: 100px 24px; background: var(--bg-light); }
  .benefits-inner { max-width: 1100px; margin: 0 auto; }
  .benefits-header { text-align: center; margin-bottom: 64px; }
  .benefits-header h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 800; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 14px;
  }
  .benefits-sub { font-size: 17px; color: var(--body); max-width: 520px; margin: 0 auto; line-height: 1.7; }
  .cards-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .benefit-card {
    border: 1px solid #e2eaee; border-radius: var(--radius-card); padding: 36px;
    background: var(--white);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s;
    position: relative; overflow: hidden;
  }
  .card-accent {
    position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }
  .benefit-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 64px rgba(27,37,89,0.1);
    border-color: var(--card-color);
  }
  .benefit-card:hover .card-accent { transform: scaleX(1); }

  .card-illustration {
    width: 100%; height: 180px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
    border-radius: 12px;
    background: #f7f9fa;
    overflow: hidden;
  }
  .card-illustration img {
    max-width: 160px; max-height: 160px;
    width: auto; height: auto;
    object-fit: contain;
    transition: transform 0.4s var(--ease-out);
  }
  .benefit-card:hover .card-illustration img { transform: scale(1.06); }

  .benefit-card h3 { font-size: 20px; font-weight: 800; color: var(--headline); margin-bottom: 10px; letter-spacing: -0.3px; }
  .benefit-card p { font-size: 14.5px; color: var(--body); line-height: 1.7; }

  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: 1fr; }
    .benefit-card { padding: 28px; }
    .card-illustration { height: 150px; }
    .card-illustration img { max-width: 130px; max-height: 130px; }
  }
</style>
