---
const base = import.meta.env.BASE_URL;
const cards = [
  {
    image: `${base}features/discovery.webp`,
    color: '#3B5BDB',
    headline: 'Patent Discovery',
    body: 'Search across 100M+ patents from 80+ global offices instantly. Type any company name and explore their full patent portfolio.',
    stat: '100M+',
    statLabel: 'patents indexed',
  },
  {
    image: `${base}features/monitoring.webp`,
    color: '#8B5CF6',
    headline: 'Competitor Monitoring',
    body: 'Get automated alerts when competitors file new patents. Monitor any technology space with real-time intelligence.',
    stat: 'Real-time',
    statLabel: 'filing alerts',
  },
  {
    image: `${base}features/reports.webp`,
    color: '#0EA5E9',
    headline: 'Reports & Analytics',
    body: 'Generate board-ready IP reports in one click. Portfolio benchmarks, green patent analysis, and technology landscapes.',
    stat: '1-click',
    statLabel: 'PDF exports',
  },
  {
    image: `${base}features/coverage.webp`,
    color: '#F97316',
    headline: 'Global Coverage',
    body: 'Access patent data from EPO, USPTO, WIPO, DPMA and 80+ offices worldwide in one unified, searchable platform.',
    stat: '80+',
    statLabel: 'patent offices',
  },
];
---
<section class="benefits">
  <div class="benefits-inner">
    <div class="benefits-header">
      <p class="section-label">Solutions</p>
      <h2>Everything you need to manage your IP</h2>
      <p class="benefits-sub">Powerful patent intelligence tools trusted by IP professionals, legal teams, and innovators worldwide.</p>
    </div>
    <div class="cards-grid">
      {cards.map(c => (
        <div class="benefit-card">
          <div class="card-image">
            <img src={c.image} alt={c.headline} loading="lazy" />
          </div>
          <div class="card-body">
            <h3>{c.headline}</h3>
            <p>{c.body}</p>
            <div class="card-stat">
              <span class="card-stat-num" style={`color: ${c.color};`}>{c.stat}</span>
              <span class="card-stat-label">{c.statLabel}</span>
            </div>
            <a href="https://app.simpleip.com" target="_blank" rel="noopener" class="card-link" style={`color: ${c.color};`}>
              Learn more
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits { padding: 100px 24px; background: var(--white); }
  .benefits-inner { max-width: 1100px; margin: 0 auto; }
  .benefits-header { text-align: center; margin-bottom: 60px; }
  .benefits-header h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 14px;
  }
  .benefits-sub { font-size: 17px; color: var(--body); max-width: 520px; margin: 0 auto; line-height: 1.7; }

  .cards-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .benefit-card {
    border: 1px solid var(--border); border-radius: var(--radius-card);
    background: var(--white); overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }
  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(27, 37, 89, 0.08);
    border-color: transparent;
  }

  .card-image {
    width: 100%; height: 260px; overflow: hidden;
    background: var(--bg-lighter);
  }
  .card-image img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .benefit-card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-body {
    padding: 28px 28px 24px;
  }
  .card-body h3 {
    font-size: 20px; font-weight: 800; color: var(--headline);
    margin-bottom: 10px; letter-spacing: -0.3px;
  }
  .card-body p {
    font-size: 14px; color: var(--body); line-height: 1.7; margin-bottom: 20px;
  }

  .card-stat { display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px; }
  .card-stat-num { font-size: 28px; font-weight: 900; letter-spacing: -0.5px; }
  .card-stat-label { font-size: 13px; color: var(--body); font-weight: 500; }

  .card-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 14px; font-weight: 700; transition: gap 0.2s;
  }
  .card-link svg { width: 14px; height: 14px; }
  .card-link:hover { gap: 10px; }

  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: 1fr; }
    .card-image { height: 200px; }
  }
</style>
