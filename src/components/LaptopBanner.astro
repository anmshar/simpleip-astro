---
---
<section class="laptop-banner">
  <img src={`${import.meta.env.BASE_URL}banner-laptop.webp`} alt="SimpleIP patent management dashboard on a MacBook" loading="lazy" />
</section>

<style>
  .laptop-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    aspect-ratio: 21 / 7;
    background: linear-gradient(180deg, #f7f9fa 0%, #f0ebe4 30%, #f0ebe4 70%, #ffffff 100%);
  }
  .laptop-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  @media (max-width: 1024px) {
    .laptop-banner { aspect-ratio: 16 / 6; }
  }
  @media (max-width: 768px) {
    .laptop-banner { aspect-ratio: 16 / 7; }
  }
  @media (max-width: 479px) {
    .laptop-banner { aspect-ratio: 16 / 8; }
  }
</style>
