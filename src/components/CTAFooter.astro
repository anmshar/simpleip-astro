---
---
<!-- Wave SVG divider from dark enterprise to light CTA -->
<div class="cta-wave-wrap">
  <svg viewBox="0 0 1440 60" fill="none" preserveAspectRatio="none">
    <path d="M0 30C240 0 480 60 720 30C960 0 1200 60 1440 30V60H0V30Z" fill="#f7f9fa"/>
  </svg>
</div>

<section class="final-cta">
  <div class="cta-inner reveal">
    <div class="cta-badge">Start today</div>
    <h2>Ready to take control of your IP?</h2>
    <p class="cta-sub">Many growing teams worldwide already use Simple IP to manage, analyze and act on their patents for free.</p>
    <button class="cta-btn-primary" onclick="openReg()">
      Find your patents
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </button>
  </div>
</section>

<style>
  .cta-wave-wrap {
    background: #183640;
    line-height: 0;
  }
  .cta-wave-wrap svg { width: 100%; height: 40px; display: block; }

  .final-cta {
    padding: 80px 24px 110px; text-align: center;
    background: #f7f9fa;
    position: relative;
  }
  .cta-inner { position: relative; max-width: 700px; margin: 0 auto; }
  .cta-badge {
    display: inline-flex; padding: 7px 18px; border-radius: 40px;
    background: rgba(38,77,90,0.08); color: var(--primary);
    font-size: 13px; font-weight: 700; margin-bottom: 24px;
    text-transform: uppercase; letter-spacing: 1px;
    border: 1px solid rgba(38,77,90,0.1);
  }
  .final-cta h2 {
    font-size: clamp(28px, 4vw, 46px); font-weight: 800; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 16px; line-height: 1.15;
  }
  .cta-sub {
    font-size: 17px; color: var(--body); margin-bottom: 40px; line-height: 1.7;
    max-width: 520px; margin-left: auto; margin-right: auto;
  }
  .cta-btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 38px; border-radius: 10px;
    background: linear-gradient(135deg, #004ED8, #0039A8);
    color: white; font-size: 16px; font-weight: 600;
    border: none; cursor: pointer;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
    box-shadow: 0 4px 20px rgba(26,77,90,0.25);
    margin-bottom: 36px;
  }
  .cta-btn-primary svg { transition: transform 0.3s; }
  .cta-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(26,77,90,0.35);
  }
  .cta-btn-primary:hover svg { transform: translateX(3px); }
  .cta-trust { display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; }
  .cta-trust-item {
    display: flex; align-items: center; gap: 7px;
    font-size: 13px; color: var(--body); font-weight: 500;
  }
  .green-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #17b26a; display: inline-block; flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .final-cta { padding: 60px 16px 80px; }
    .final-cta h2 { font-size: 26px; letter-spacing: -1px; }
    .cta-sub { font-size: 15px; margin-bottom: 32px; }
    .cta-btn-primary { padding: 13px 28px; font-size: 15px; width: 100%; max-width: 320px; justify-content: center; }
    .cta-trust { gap: 16px; }
    .cta-trust-item { font-size: 12px; }
    .cta-badge { font-size: 12px; padding: 6px 14px; }
  }

  @media (max-width: 480px) {
    .final-cta { padding: 48px 14px 64px; }
    .final-cta h2 { font-size: 22px; letter-spacing: -0.5px; }
    .cta-sub { font-size: 14px; margin-bottom: 28px; }
    .cta-btn-primary { padding: 12px 24px; font-size: 14px; }
    .cta-trust { flex-direction: column; gap: 10px; align-items: center; }
    .cta-trust-item { font-size: 12px; }
    .cta-badge { font-size: 11px; padding: 5px 12px; }
  }
</style>
