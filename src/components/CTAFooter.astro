---
---
<section class="final-cta">
  <div class="cta-inner">
    <div class="cta-badge">Start for free today</div>
    <h2>Ready to take control of your patent portfolio?</h2>
    <p class="cta-sub">Join thousands of IP professionals using SimpleIP to discover, monitor, and manage their patents. Free forever.</p>
    <div class="cta-actions">
      <a href="/register" class="cta-btn-primary">Create your free account</a>
      <a href="/#features" class="cta-btn-secondary">See all features</a>
    </div>
    <div class="cta-trust">
      <div class="cta-trust-item">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l3 3 5-5"/></svg>
        No credit card required
      </div>
      <div class="cta-trust-item">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l3 3 5-5"/></svg>
        Free forever
      </div>
      <div class="cta-trust-item">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l3 3 5-5"/></svg>
        Setup in under 2 minutes
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 100px 24px; text-align: center;
    background: var(--bg-light); position: relative; overflow: hidden;
  }
  .cta-inner { position: relative; max-width: 700px; margin: 0 auto; }
  .cta-badge {
    display: inline-flex; padding: 6px 16px; border-radius: 40px;
    background: rgba(59, 91, 219, 0.08); color: var(--primary);
    font-size: 13px; font-weight: 700; margin-bottom: 24px;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .final-cta h2 {
    font-size: clamp(28px, 4vw, 44px); font-weight: 900; color: var(--headline);
    letter-spacing: -1.5px; margin-bottom: 16px; line-height: 1.15;
  }
  .cta-sub {
    font-size: 17px; color: var(--body); margin-bottom: 36px; line-height: 1.7;
    max-width: 520px; margin-left: auto; margin-right: auto;
  }
  .cta-actions { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
  .cta-btn-primary {
    display: inline-flex; padding: 16px 36px; border-radius: 12px;
    background: var(--primary); color: var(--white);
    font-size: 16px; font-weight: 700;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .cta-btn-primary:hover {
    background: var(--primary-light); transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(59, 91, 219, 0.3);
  }
  .cta-btn-secondary {
    display: inline-flex; padding: 16px 36px; border-radius: 12px;
    background: var(--white); color: var(--headline); border: 1px solid var(--border);
    font-size: 16px; font-weight: 700;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .cta-btn-secondary:hover {
    border-color: var(--primary); transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }
  .cta-trust { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; }
  .cta-trust-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--body); font-weight: 500;
  }
  .cta-trust-item svg { width: 14px; height: 14px; color: var(--green); }
</style>
