---
const cards = [
  {
    icon: 'icons/countries.png',
    stat: '180+',
    statLabel: 'JURISDICTIONS',
    title: 'Coverage you can count on',
    body: 'Access patent data and expert services across 180+ jurisdictions worldwide.',
  },
  {
    icon: 'icons/support.png',
    stat: '20+',
    statLabel: 'GLOBAL OFFICES',
    title: 'A truly global IP group',
    body: 'Dennemeyer operates worldwide with over 20 offices, bringing local expertise to every market.',
  },
  {
    icon: 'icons/gdpr.png',
    stat: 'GDPR',
    statLabel: 'COMPLIANT',
    title: 'Enterprise-grade security',
    body: 'Your data is encrypted and GDPR compliant.',
  },
];
---
<section class="enterprise">
  <!-- Dot grid overlay -->
  <div class="ent-dot-grid"></div>
  <!-- Orange radial glow -->
  <div class="ent-glow"></div>

  <div class="enterprise-inner">
    <div class="reveal">
      <h2>Built on over 60 years of IP expertise.</h2>
      <p class="enterprise-sub">Simple IP is built by Dennemeyer, one of the world's leading IP groups, trusted by global enterprises since 1962.</p>
    </div>
    <div class="trust-cards">
      {cards.map((c, i) => (
        <div class={`trust-card reveal reveal-delay-${i}`}>
          <div class="trust-card-icon"><img src={`${import.meta.env.BASE_URL}${c.icon}`} alt="" /></div>
          <div class="trust-card-stat">
            <span class="tcs-num">{c.stat}</span>
            <span class="tcs-label">{c.statLabel}</span>
          </div>
          <h4>{c.title}</h4>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .enterprise {
    padding: 110px 24px; text-align: center;
    background-color: #1e3d57;
    background-image:
      linear-gradient(180deg, rgba(5, 24, 80, 0.20) 0%, rgba(5, 24, 80, 0.05) 100%),
      url('/hero-banner.webp');
    background-repeat: no-repeat, no-repeat;
    background-size: cover, cover;
    background-position: center, center;
    position: relative; overflow: hidden;
  }
  .ent-dot-grid {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 32px 32px; pointer-events: none;
  }
  .ent-glow {
    position: absolute; top: -100px; right: -100px;
    width: 500px; height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,108,45,0.15), transparent 70%);
    filter: blur(60px); pointer-events: none;
  }
  .enterprise-inner { position: relative; max-width: 1100px; margin: 0 auto; }
  .enterprise h2 {
    font-size: clamp(28px, 3.5vw, 42px); font-weight: 800; color: var(--white);
    letter-spacing: -1.5px; margin-bottom: 14px;
  }
  .enterprise-sub {
    font-size: 16px; color: rgba(255,255,255,0.5); max-width: 580px;
    margin: 0 auto 60px; line-height: 1.7;
  }
  .trust-cards {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .trust-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px; padding: 36px; text-align: left;
    backdrop-filter: blur(12px);
    transition: background 0.4s, border-color 0.4s, transform 0.4s var(--ease-out), box-shadow 0.4s;
    position: relative; overflow: hidden;
  }
  /* Shimmer line */
  .trust-card::before {
    content: ''; position: absolute; top: 0; left: -100%; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.6s;
  }
  .trust-card:hover::before { left: 100%; }
  .trust-card:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .trust-card-icon { margin-bottom: 16px; }
  .trust-card-icon img { width: 64px; height: 64px; object-fit: contain; filter: invert(1); opacity: 0.85; }
  .trust-card-stat {
    display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px;
  }
  .tcs-num { font-size: 32px; font-weight: 800; color: var(--white); letter-spacing: -0.5px; }
  .tcs-label { font-size: 12px; color: rgba(255,255,255,0.4); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .trust-card h4 { font-size: 17px; font-weight: 700; color: var(--white); margin-bottom: 10px; }
  .trust-card p { font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.7; }

  @media (max-width: 1024px) {
    .enterprise { padding: 80px 20px; }
    .trust-cards { gap: 16px; }
    .trust-card { padding: 28px; }
    .tcs-num { font-size: 28px; }
    .trust-card h4 { font-size: 16px; }
    .trust-card p { font-size: 13px; }
  }

  @media (max-width: 768px) {
    .enterprise { padding: 72px 16px; }
    .enterprise h2 { font-size: 26px; letter-spacing: -1px; }
    .enterprise-sub { font-size: 14px; margin-bottom: 40px; }
    .trust-cards { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; gap: 16px; }
    .trust-card { padding: 28px; }
    .tcs-num { font-size: 28px; }
    .trust-card h4 { font-size: 16px; }
    .trust-card p { font-size: 13px; }
    .trust-card-icon img { width: 52px; height: 52px; }
  }

  @media (max-width: 480px) {
    .enterprise { padding: 56px 14px; }
    .enterprise h2 { font-size: 22px; }
    .enterprise-sub { font-size: 13px; }
    .trust-card { padding: 22px; }
    .trust-card-icon img { width: 44px; height: 44px; }
    .tcs-num { font-size: 24px; }
  }
</style>
